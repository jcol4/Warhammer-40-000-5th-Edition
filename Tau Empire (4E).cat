  <sharedSelectionEntryGroups>
    <selectionEntryGroup name="Vehicle Armoury" id="cc37-0241-b035-5cf9" hidden="false">
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Decoy Launchers" hidden="false" id="3e8b-7fdf-a74c-43e0">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="ad1e-7899-6a3c-144f" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="Decoy Launchers" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="120e-8048-6e65-7613">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Whenever an Immobilised result is rolled on the Glancing Hit Vehicle Damage Table, the Tau player may force his opponent to re-roll  the dice, though the second result stands, even if it is worse.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="5"/>
          </costs>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Disruption Pod" hidden="false" id="79e0-c0d2-676b-0fd2">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="00a0-16cf-d665-e112" includeChildSelections="false"/>
          </constraints>
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="5"/>
          </costs>
          <profiles>
            <profile name="Disruption Pod" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="c843-01f7-b8c6-453f">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Weapons firing at the vehicle from more than 12&quot; away count the vehicle as an Obscured Target.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Flechette Discharger" hidden="false" id="b479-4e81-5541-33c0">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="3271-a3f1-f2ec-417d" includeChildSelections="false"/>
          </constraints>
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="10"/>
          </costs>
          <profiles>
            <profile name="Flechette Discharger" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="88c0-f794-5548-193e">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Any model attacking the vehicle in close combat will be wounded on a D6 roll of 4+, with Saves allowed, before resolving its attacks.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Target Lock" hidden="false" id="25b1-3729-4786-3d43">
          <comment>For vehicles</comment>
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="ecf1-93f3-21b2-75d9" includeChildSelections="false"/>
            <constraint type="min" value="0" field="selections" scope="parent" shared="true" id="fae0-2f99-0d44-0280" automatic="true"/>
          </constraints>
          <profiles>
            <profile name="Target Lock" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="e931-edca-462f-ba1a">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A target lock allows each weapon on the vehicles to fire at a separate enemy unit if desired, subject to the normal line of sight rules.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="5"/>
          </costs>
          <modifiers>
            <modifier type="set" value="1" field="fae0-2f99-0d44-0280">
              <conditions>
                <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="e2a1-a555-3372-33aa" shared="true"/>
              </conditions>
            </modifier>
            <modifier type="set" value="0" field="4deb-313d-6685-f48b">
              <conditions>
                <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="e2a1-a555-3372-33aa" shared="true"/>
              </conditions>
            </modifier>
          </modifiers>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Sensor Spines" hidden="false" id="1f6b-294b-1536-af25">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="8c20-8a53-1a2c-1c6e" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="Sensor Spines" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="b2bb-77ee-bfc1-11f5">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The vehicle may opt to use the sensor spines instead of moving normally. Whilst doing so the vehicle does not hover above a terrain feature - instead, it is counted as actually moving through it. It may therefore claim to be an obscured target in the same way as a normal vehicle in the same position, but the sensors allow it to ignore the effects of dangerous terrain.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="10"/>
          </costs>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Blacksun Filter" hidden="false" id="96ce-241c-e3a0-3927">
          <profiles>
            <profile name="Blacksun Filter" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="d608-fe82-e4ce-938a">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Allows the vehicle to double the distance rolled for determining how far they can see when using the Night Fighting mission special rules.</characteristic>
              </characteristics>
              <comment>For non-vehicles</comment>
            </profile>
          </profiles>
          <comment>For vehicles</comment>
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="dbec-d2aa-5c80-c75f" includeChildSelections="false"/>
          </constraints>
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="5"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
      <entryLinks>
        <entryLink import="true" name="Seeker Missile" hidden="false" id="0d6f-a9ed-cc7b-e218" type="selectionEntry" targetId="db60-5dab-709b-9e99">
          <constraints>
            <constraint type="max" value="2" field="selections" scope="parent" shared="true" id="e62f-634d-487d-51ac" includeChildSelections="false"/>
          </constraints>
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="10"/>
          </costs>
          <modifiers>
