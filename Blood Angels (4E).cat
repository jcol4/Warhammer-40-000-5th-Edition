                      </constraints>
                      <profiles>
                        <profile name="Blood Angels Chapter Banner" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="bb27-4492-56a0-1f9c">
                          <characteristics>
                            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Any Blood Angels unit within 12&quot; of the standard may re-roll any failed Morale and Pinning tests. In addition, all models win the standard bearer&apos;s unit adds 1 to their Attacks characteristic.</characteristic>
                          </characteristics>
                        </profile>
