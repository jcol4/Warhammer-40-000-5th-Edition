      <rules>
        <rule name="Supremely Inspiring Presence" id="2918-967b-0297-fc0d" hidden="false">
          <description>All Tau units (not Kroot, Vespid, or drones) with a line of sight to Aun&apos;Va are counted as Stubborn. If the Night Fighting rules are in use, roll to determine if the unit can see the Ethereal.</description>
        </rule>
        <rule name="Ultimate Price of Failure" id="f410-4dee-73c0-a9f9" hidden="false">
          <description>Should Aun&apos;Va be removed as a casualty, every Tau unit on the table (not Kroot, Vespids, or drones) must take a Morale check if they are not in close combat or falling back. Every unit that takes the test gains the Preferred Enemy universal special rule in relation to the enemy army, and in addition gains the Furious Charge universal special rule.</description>
        </rule>
      </rules>
      <costs>
        <cost name="Points" typeId="4deb-313d-6685-f48b" value="205"/>
      </costs>
    </selectionEntry>
