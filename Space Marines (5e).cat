      </categoryLinks>
      <costs>
        <cost name="Points" typeId="4deb-313d-6685-f48b" value="250"/>
      </costs>
      <profiles>
        <profile name="Land Raider" typeId="56656869636c6523232344415441232323" typeName="Vehicle" hidden="false" id="lr5e-veh-prof-0001">
          <characteristics>
            <characteristic name="BS" typeId="a6a5-1595-da9e-6155">4</characteristic>
            <characteristic name="Front" typeId="46726f6e7423232344415441232323">14</characteristic>
            <characteristic name="Side" typeId="5.369646523232344e+27">14</characteristic>
            <characteristic name="Rear" typeId="5.265617223232345e+27">14</characteristic>
            <characteristic name="Type" typeId="5.479706523232345e+27">Vehicle (Tank)</characteristic>
          </characteristics>
        </profile>
        <profile name="Land Raider" typeId="307d-047f-ca13-706b" typeName="Transport" hidden="false" id="lr5e-trn-prof-0001">
          <characteristics>
            <characteristic name="Capacity" typeId="8285-4205-b6cd-8473">12 models</characteristic>
            <characteristic name="Fire Points" typeId="b270-a7f9-22b2-3702">0</characteristic>
            <characteristic name="Access Points" typeId="d17b-0342-b1dc-b8e7">One on each side of the hull, one at the front</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule name="Power of the Machine Spirit" id="lr5e-poms-rule-0001" hidden="false">
          <description>A Land Raider can fire one more weapon than would normally be permitted. In addition, this weapon can be fired at a different target unit to any other weapons, subject to the normal rules for Shooting. Therefore, a Land Raider that has moved at combat speed can fire two weapons, and a Land Raider that has either moved at cruising speed, or has suffered a &apos;Crew Stunned&apos; or &apos;Crew Shaken&apos; result can fire a single weapon.</description>
        </rule>
        <rule name="Assault Vehicle" id="lr5e-av-rule-0001" hidden="false">
          <description>Models disembarking from any access point on a Land Raider can launch an assault on the turn they do so.</description>
        </rule>
      </rules>
