      <rules>
        <rule name="Headstrong" id="2edd-a3ca-9bf1-9042" hidden="false">
          <description>Blood Claws must charge if one of their models is within 6&quot; of the enemy, unless the pack is being led by a character. They must advance after defeating an enemy, and may never</description>
        </rule>
        <rule name="Berserk Charge" id="580b-46ae-9a67-0746" hidden="false">
          <description>Blood Claws receive a bonus of +2 Attacks when they charge, rather than only +1 Attack as is normally the case. Note that this only applies to Blood Claws and not to Wolf Guard Leaders or to characters that have joined the pack.</description>
        </rule>
      </rules>
    </selectionEntry>
