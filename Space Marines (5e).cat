      <selectionEntryGroups>
        <selectionEntryGroup name="Weapon Configuration" id="mof0-wpncfg-grp-0001" hidden="false" collective="false" import="true" defaultSelectionEntryId="mof0-sh-entry-0001">
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="false" id="mof0-wpncfg-co01" percentValue="false" includeChildSelections="false" includeChildForces="false"/>
