        <selectionEntryGroup name="Psychic Powers" id="d6a9-8309-1f81-2ff2" hidden="false">
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Wings of Sanguinius" hidden="false" id="b1d6-33fa-1232-5363">
              <constraints>
                <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="ce9d-78ed-1ea7-e9fc-min" includeChildSelections="false"/>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="ce9d-78ed-1ea7-e9fc-max" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="Wings of Sanguinius" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="5b2d-94a9-6675-6e31">
                  <characteristics>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">This power is used in the Movement Phase and lasts for the rest of the turn. It allows the Librarian to move as if he had a Jump Pack. A Librarian wearing Terminator armor can use the Wings of Sanguinius. A Librarian riding a bike that uses the Wings of Sanguinius counts as riding a jetbike.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Might of Heroes" hidden="false" id="b9c9-ff8c-f1ed-f7eb">
              <constraints>
                <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="e081-aa74-5241-5818-min" includeChildSelections="false"/>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="e081-aa74-5241-5818-max" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="Might of Heroes" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="3681-818b-b616-aa27">
                  <characteristics>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">The power is used at the start of either player’s Assault Phase, and if successful, the Librarian (or any one other model in the same unit as the Librarian) gains +D3 attacks in that Assault Phase.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
          </selectionEntries>
        </selectionEntryGroup>
      </selectionEntryGroups>
