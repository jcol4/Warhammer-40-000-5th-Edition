              <rules>
                <rule name="Orbital Bombardment" id="cm-ob-rule-0001" hidden="false">
                  <description>Once per game, providing that the Chapter Master did not move in the preceding movement phase (though he may later assault if the controlling player wishes), the Chapter Master may call down an orbital bombardment. Calling down an orbital bombardment otherwise counts as firing a ranged weapon, and uses the following profile: Range Unlimited, S10, AP1, Ordnance 1, Barrage. Note that if an arrow is rolled on the scatter dice an orbital bombardment will always scatter the full 2D6&quot; - the Chapter Master&apos;s Ballistic Skill makes no difference.</description>
                </rule>
              </rules>
              <profiles>
                <profile name="Orbital Bombardment" typeId="576561706f6e23232344415441232323" typeName="Weapon" hidden="false" id="cm-ob-wpn-0001">
                  <characteristics>
                    <characteristic name="Range" typeId="52616e676523232344415441232323">Unlimited</characteristic>
                    <characteristic name="Strength" typeId="537472656e67746823232344415441232323">10</characteristic>
                    <characteristic name="AP" typeId="4.1502323234441545e+23">1</characteristic>
                    <characteristic name="Type" typeId="8b10-045a-f593-605e">Ordnance 1, Barrage</characteristic>
                    <characteristic name="Info" typeId="33e9-27bd-77e4-401d"/>
                  </characteristics>
                </profile>
