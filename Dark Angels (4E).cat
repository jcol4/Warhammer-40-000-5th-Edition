    <selectionEntry type="upgrade" import="true" name="Space Marine Bike" hidden="false" id="ae8e-ca79-f116-8d05">
      <profiles>
        <profile name="Space Marine Bike" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="6aea-e081-0edd-7976">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Models with Space Marine Bikes follow all rules for Bikes and are equipped with twin-linked bolters.</characteristic>
          </characteristics>
        </profile>
        <profile name="Teleport Homer" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="3fa1-2850-cd5f-1a1c">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">If Terminators wish to teleport onto the battlefield via Deep Strike and choose to do so within 6&quot; of the model carrying the teleport homer, then they won&apos;t scatter. Note that the homer only worked for squads who are teleporting, not for squads entering play using jump packs, drop pods or other means of transport. Also note that the homer must already be on the table at the start of the turn for it to be used.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <modifiers>
        <modifier type="append" value="(5)" field="5.423232344415441e+21" scope="parent" affects="self.entries.profiles.Unit" join=" " position="3"/>
        <modifier type="replace" value="Bike" field="556e6974205479706523232344415441232323" affects="self.entries.profiles.Unit" scope="parent" arg="Infantry"/>
      </modifiers>
      <infoLinks>
