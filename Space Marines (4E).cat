    <selectionEntry type="model" import="true" name="Attack Bike" hidden="false" id="89e8-fb61-d518-15f2">
      <profiles>
        <profile name="Attack Bike" typeId="556e697423232344415441232323" typeName="Unit" hidden="false" id="e30a-b06c-9fc0-cbd2">
          <characteristics>
            <characteristic name="Unit Type" typeId="556e6974205479706523232344415441232323">Bike</characteristic>
            <characteristic name="WS" typeId="5.753232323444154e+23">4</characteristic>
            <characteristic name="BS" typeId="4.2532323234441546e+23">4</characteristic>
