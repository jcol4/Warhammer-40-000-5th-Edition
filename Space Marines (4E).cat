      <constraints>
        <constraint type="max" value="0" field="selections" scope="roster" shared="true" id="c99f-b068-f5fc-c6e0" includeChildSelections="true" includeChildForces="true" automatic="false"/>
      </constraints>
      <rules>
        <rule name="Tyranid Hunter" id="04a0-656b-a23a-c779" hidden="false">
          <description>Chaplain Cassius and any Ultramarines squad led by him benefit from the Preferred Enemy (Tyranids) special rule.</description>
        </rule>
        <rule name="Great Knowledge" id="e504-db94-4451-0692" hidden="false">
          <description>Any Ultramarine squad within 6&quot; of Cassius may re-roll their Morale checks, accepting the second result as final. Note that this ability can be used even if a Morale check is passed on the first roll, so you can use it to try to make sure Ultramarines fall back in disadvantageous or dangerous situations.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink name="Honour of the Chapter" id="bd5e-bbf2-2846-dd29" hidden="false" type="rule" targetId="9cb2-4889-4b6c-190d"/>
        <infoLink name="Litanies of Hate" id="ca58-02fe-df50-eec1" hidden="false" type="rule" targetId="99d7-eaaa-fb97-4d39"/>
        <infoLink name="And They Shall Know No Fear" id="c6d5-5e59-1fe4-f298" hidden="false" type="rule" targetId="8eaf-de62-f965-125b"/>
      </infoLinks>
      <costs>
        <cost name="Points" typeId="4deb-313d-6685-f48b" value="160"/>
      </costs>
    </selectionEntry>
