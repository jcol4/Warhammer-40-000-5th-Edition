                    <condition type="atLeast" value="1" field="selections" scope="force" childId="5129-52fb-efe2-22a3" shared="true" includeChildSelections="true"/>
                    <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="39ab-2bcd-49d1-cfef" shared="true"/>
                  </conditions>
                </conditionGroup>
              </conditionGroups>
            </modifier>
          </modifiers>
          <rules>
            <rule name="Venerable Dreadnought" id="ef62-df82-dd3f-b9e0" hidden="false">
              <description>Venerable Dreadnought are extremely hard to kill and whenever they suffer a glancing or penetrating hit you may ask your opponent to re-roll the result on the Vehicle Damage tables. However, you much accept the second result, even if it is worse.</description>
            </rule>
          </rules>
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="20"/>
          </costs>
        </selectionEntry>
