        <selectionEntry type="upgrade" import="true" name="Rosarius" hidden="false" id="f736-aadf-16e3-22ac" sortIndex="3">
          <profiles>
            <profile name="Rosarius" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="6b41-11b2-dfdd-4978">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The Rosarius generates an energy field that provides the Chaplain with a 4+ Invulnerable Save. This may be taken instead of the Chaplain&apos;s normal Armour Save.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="28ec-0b59-d359-bf02-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="28ec-0b59-d359-bf02-max" includeChildSelections="false"/>
