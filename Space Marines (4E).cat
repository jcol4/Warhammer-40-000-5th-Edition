      </constraints>
      <profiles>
        <profile name="Terminator Armour" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="3f6b-ceec-fad3-5e44">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A model wearing Terminator armour has a 2+ Armour Save and a 5+ Invulnerable Save. The wearer automatically has Terminator Honours at no additional cost.
Any model wearing Terminator armour can be teleported onto the battlefield. They can start the battle in Reserve and arrive using the Deep Strike special rule, even if it is not part of the mission being played.</characteristic>
          </characteristics>
        </profile>
        <profile name="Terminator Honours" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="c41a-ad49-3fd1-c456">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323"/>
          </characteristics>
        </profile>
      </profiles>
      <modifiers>
        <modifier type="set" value="2+" field="5.361766523232344e+27" scope="root-entry" affects="self.entries.profiles.Unit"/>
        <modifier type="set" value="true" field="hidden">
          <conditionGroups>
            <conditionGroup type="and">
              <conditionGroups>
                <conditionGroup type="or">
                  <conditions>
                    <condition type="instanceOf" value="1" field="selections" scope="parent" childId="terminatorsergeant" shared="true"/>
                    <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="1202-16ac-4bf1-c237" shared="true"/>
                    <condition type="atLeast" value="1" field="selections" scope="root-entry" childId="0dd7-5b1d-713c-3818" shared="true"/>
                    <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="1507-f6be-3680-5e10" shared="true"/>
                    <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="306d-a124-7618-8d4f" shared="true"/>
                    <condition type="atLeast" value="1" field="selections" scope="force" childId="213a-8bf1-e310-6baa" shared="true" includeChildSelections="true"/>
                  </conditions>
                  <conditionGroups>
                    <conditionGroup type="and">
                      <conditions>
                        <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="sergeant1" shared="true"/>
                        <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="9936-1255-bf77-b8fe" shared="true"/>
                      </conditions>
                    </conditionGroup>
                    <conditionGroup type="and">
                      <conditions>
                        <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="sergeant1" shared="true"/>
                        <condition type="equalTo" value="0" field="selections" scope="force" childId="ffc4-9fce-350d-21ca" shared="true" includeChildSelections="true"/>
                      </conditions>
                    </conditionGroup>
                  </conditionGroups>
                </conditionGroup>
              </conditionGroups>
            </conditionGroup>
          </conditionGroups>
        </modifier>
        <modifier type="floor" value="9" field="4c4423232344415441232323" affects="self.entries.profiles.Unit" position="1" scope="parent"/>
        <modifier type="increment" value="1" field="4.123232344415441e+21" affects="self.entries.profiles.Unit" scope="parent"/>
