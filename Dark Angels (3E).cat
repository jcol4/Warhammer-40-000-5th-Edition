      <infoLinks>
        <infoLink name="Ravenwing" id="d145-003c-4481-fd79" hidden="false" type="rule" targetId="fbf9-5752-f4f1-414a"/>
      </infoLinks>
      <rules>
        <rule name="All-Seeing Eye" id="4dbf-8d0e-a5d3-b8c6" hidden="false">
          <description>The Ravenwing player may re-roll all To Hit rolls for a single Ravenwing unit of his choice in each Shooting phase, as long as the Master of the Ravenwing is on the table. Alternatively, in any missions using the Night Fighting rules the Ravenwing player may double the distance one unit may &apos;see&apos;.</description>
        </rule>
        <rule name="Shield of Night" id="bbf9-0b1d-dae3-9450" hidden="false">
          <description>A protective energy field generated around the Land Speeder gives it a 4+ Invulnerable Save against any glancing or penetrating hits. This replaces the 6+ save Ravenwing vehicles normally receive for &apos;jinking&apos;.</description>
        </rule>
      </rules>
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="The Raven Sword" hidden="false" id="36e2-449c-16b0-34ca" sortIndex="1">
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="0"/>
          </costs>
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="5156-c81a-e097-e1bd-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="5156-c81a-e097-e1bd-max" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="The Raven Sword" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="0f72-5096-02b2-d814">
              <characteristics>
                <characteristic name="Details" typeId="acf3-d214-6e51-29fe">When wielded by a Master of the Ravenwing mounted on a Land Speeder, the Raven Sword allows the master to make a special attack if he moves within 2&quot; of an enemy model in the Movement phase. He may make a single roll to hit as if he were making a close combat attack on the enemy model with a Weapon Skill of 5. The enemy may not strike back. If the attack hits it causes a S6 hit with no Armour Save allowed. The Master may only make on attack with the Raven Sword per turn. Attacking with this weapon does not stop the Land Speeder shooting in the Shooting phase. If the Master attacks with the Raven sword, neither he or his target count as being Locked or Enganged</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
    </selectionEntry>
