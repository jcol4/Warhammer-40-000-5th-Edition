      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Exsanguinator" hidden="false" id="f2b5-4daf-0d29-fabf" sortIndex="3">
          <profiles>
            <profile name="Exsanguinator" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="a98c-3ef0-9fd3-f1e9">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Once per player turn, a friendly model within 6&quot; of a model with an Exsanguinator may ignore
a failed save as long as the bearer is not Falling Back, in close combat, or Pinned. It may not be used against Instant Death or a close combat attack that ignores armor saves.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="4227-81df-2591-ee95-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="4227-81df-2591-ee95-max" includeChildSelections="false"/>
          </constraints>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="The Red Grail" hidden="false" id="3af0-4716-9c73-f135" sortIndex="4">
          <profiles>
            <profile name="The Red Grail" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="87f3-1995-9cd2-ea0b">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Any Blood Angel unit within 12&quot; of Corbulo at the start of one of its own Assault Phases receives the Furious Charge ability for the rest of the turn. In addition, the Grail generates a powerful force field
that provides the model holding the Grail with a 4+ invulnerable save.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="14ac-14db-7586-c39d-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="14ac-14db-7586-c39d-max" includeChildSelections="false"/>
          </constraints>
        </selectionEntry>
