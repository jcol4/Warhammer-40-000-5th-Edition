          </modifiers>
        </profile>
        <profile name="Daemonic Steed (Juggernaut of Khorne)" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="true" id="e53b-395c-51b9-f936">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">A Juggernaut of Khorne confers to the rider +1 Attack and +1 Strength. The model can not be carried in transports.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="parent" childId="a886-8c94-f3d4-d8c0" shared="true" childName="Mark of Khorne"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Daemonic Steed (Disc of Tzeentch)" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="true" id="e88a-d532-f4c4-bfae">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">A Disc of Tzeentch confers to the rider +1 Attack and changes the unit type of the model to Jump Infantry.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="parent" childId="2b54-9305-b1dd-a202" shared="true" childName="Mark of Tzeentch"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Daemonic Steed (Palanquin of Nurgle)" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="true" id="bb15-d510-63d7-4b12">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">A Palanquin of Nurgle confers to the rider +1 Attack and +1 Wound. The model may not be carried in a Chaos Rhino, but may be carried in a Chaos Land Raider counting as two models.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="parent" childId="4150-9784-b68a-93c4" shared="true" childName="Mark of Nurgle"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
      </profiles>
