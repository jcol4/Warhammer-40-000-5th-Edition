  <sharedSelectionEntries>
    <selectionEntry type="upgrade" import="true" name="Daemon Weapon" hidden="false" id="87bc-80d8-c4a2-fe61">
      <profiles>
        <profile name="Daemon Weapon" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="156c-cb0e-183d-0d28">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">A Daemon Weapon is a two-handed power weapon that adds an extra D6 Attacks in close combat. If the result is a 1, then the model may not make any attacks in this round and suffers one wound with no Armour Saves allowed. The weapon can have additional abilities depending on the Mark of Chaos given to the bearer.
A basic Daemon Weapon grants the wielder +1 Strength in close combat.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="true" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="parent" childId="3cea-4814-be0e-6d97" shared="true" childName="Marks of Chaos"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Daemon Weapon (Bloodfeeder)" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="true" id="b40e-4d2a-57b6-ca9a">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">A Daemon Weapon is a two-handed power weapon that adds an extra D6 Attacks in close combat. If the result is a 1, then the model may not make any attacks in this round and suffers one wound with no Armour Saves allowed. The weapon can have additional abilities depending on the Mark of Chaos given to the bearer.
A model with a Bloodfeeder against 2D6 attacks rather than D6. If either of the dice is a 1, the model does not attack and suffers one wound as described above (not one wound for each 1 rolled)</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="parent" childId="a886-8c94-f3d4-d8c0" shared="true" childName="Mark of Khorne"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Daemon Weapon (Blissgiver)" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="true" id="3671-c829-364c-205c">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">A Daemon Weapon is a two-handed power weapon that adds an extra D6 Attacks in close combat. If the result is a 1, then the model may not make any attacks in this round and suffers one wound with no Armour Saves allowed. The weapon can have additional abilities depending on the Mark of Chaos given to the bearer.
Any models caused on the enemy by a Blissgiver inflict Instant Death, regardless of the target&apos;s Toughness.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="parent" childId="9286-dbf9-b296-edf2" shared="true" childName="Mark of Slaanesh"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Daemon Weapon (Deathscreamer)" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="true" id="9334-7f5d-cae2-4643">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">A Daemon Weapon is a two-handed power weapon that adds an extra D6 Attacks in close combat. If the result is a 1, then the model may not make any attacks in this round and suffers one wound with no Armour Saves allowed. The weapon can have additional abilities depending on the Mark of Chaos given to the bearer.
The Deathscreamer can be fired in the Shooting phase, with the related profile. If a 1 is rolled for the number of shots, no shots are fired and the wilder suffers a wound with no Armour Save allowed.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="parent" childId="2b54-9305-b1dd-a202" shared="true" childName="Mark of Tzeentch"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Daemon Weapon (Plaguebringer)" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="true" id="80bb-f3db-9620-aa54">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">A Daemon Weapon is a two-handed power weapon that adds an extra D6 Attacks in close combat. If the result is a 1, then the model may not make any attacks in this round and suffers one wound with no Armour Saves allowed. The weapon can have additional abilities depending on the Mark of Chaos given to the bearer.
A model with a Plaguebringer has Poisoned Attacks that wound on a 4+.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="parent" childId="4150-9784-b68a-93c4" shared="true" childName="Mark of Nurgle"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Daemon Weapon (Deathscreamer)" typeId="576561706f6e23232344415441232323" typeName="Weapon" hidden="true" id="e322-356f-779c-654d">
          <characteristics>
