    <selectionEntry type="unit" import="true" name="Drop Pod" hidden="false" id="drop-pod-0001-0001" publicationId="b8b3-96de-ab2d-52b7" page="82">
      <categoryLinks>
        <categoryLink name="Dedicated Transport" hidden="false" id="drop-pod-cat-0001" targetId="ded0-5000-0001-0001" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="Points" typeId="4deb-313d-6685-f48b" value="35"/>
      </costs>
      <profiles>
        <profile name="Drop Pod" typeId="56656869636c6523232344415441232323" typeName="Vehicle" hidden="false" id="drop-pod-prof-0001">
          <characteristics>
            <characteristic name="BS" typeId="a6a5-1595-da9e-6155">4</characteristic>
            <characteristic name="Front" typeId="46726f6e7423232344415441232323">12</characteristic>
            <characteristic name="Side" typeId="5.369646523232344e+27">12</characteristic>
            <characteristic name="Rear" typeId="5.265617223232345e+27">12</characteristic>
            <characteristic name="Type" typeId="5.479706523232345e+27">Vehicle (Open Topped)</characteristic>
          </characteristics>
        </profile>
        <profile name="Drop Pod" typeId="307d-047f-ca13-706b" typeName="Transport" hidden="false" id="drop-pod-prof-0002">
          <characteristics>
            <characteristic name="Capacity" typeId="8285-4205-b6cd-8473">12 models or 1 Dreadnought</characteristic>
            <characteristic name="Fire Points" typeId="b270-a7f9-22b2-3702">0</characteristic>
            <characteristic name="Access Points" typeId="d17b-0342-b1dc-b8e7">One hatch</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule name="Drop Pod Assault" id="drop-pod-rule-0001" hidden="false">
          <description>The Drop Pod has the Deep Strike special rule. At the beginning of the first turn, you must choose half of your Drop Pods (rounding up) to make a Drop Pod Assault. Units making a Drop Pod Assault arrive on the player&apos;s first turn. The arrival of remaining Drop Pods is rolled for as normal. A unit that arrives via Drop Pod may not assault in the turn it arrives.</description>
        </rule>
        <rule name="Inertial Guidance System" id="drop-pod-rule-0002" hidden="false">
          <description>Should a Drop Pod scatter on top of impassable terrain or another model (friend or foe!) then reduce the scatter distance by the minimum amount required in order to avoid the obstacle.</description>
        </rule>
        <rule name="Immobile" id="drop-pod-rule-0003" hidden="false">
          <description>A Drop Pod cannot move once it has entered the battle, and counts in all respects as a vehicle that has suffered an Immobilised damage result (which cannot be repaired in any way).</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink name="Deep Strike" id="drop-pod-il-0001" hidden="false" targetId="bbf5-b1c2-49b0-f3c2" type="rule"/>
      </infoLinks>
      <selectionEntryGroups>
        <selectionEntryGroup name="Armament" id="drop-pod-grp-0001" hidden="false" collective="false" import="true" defaultSelectionEntryId="drop-pod-sb-0001">
