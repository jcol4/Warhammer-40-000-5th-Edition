                    <characteristic name="Strength" typeId="12da-9b3e-f37b-bc35">2D6-2</characteristic>
                    <characteristic name="AP" typeId="10b5-aa5b-ccde-79cc">D6</characteristic>
                    <characteristic name="Type" typeId="20e7-cbcb-1781-a732">Assault 1</characteristic>
                    <characteristic name="Details" typeId="a812-390d-dff6-dabd">A Psychic test must be passed in order to use this power. Roll once for the Strength and AP of the attack each time you shoot; don&apos;t roll separately for each target you hit. If the Strength is 0 then the attack has no effect.</characteristic>
                  </characteristics>
