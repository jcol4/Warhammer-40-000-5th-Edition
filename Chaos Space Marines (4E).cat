  <sharedRules>
    <rule name="Invulnerable Save (5+)" id="19a3-452b-90f7-2126" hidden="false">
      <description>This model has an Invulnerable Save of 5+.</description>
      <modifierGroups>
        <modifierGroup type="and">
          <modifiers>
            <modifier type="replace" value="4+ (from Mark of Tzeentch)." field="description" arg="5+"/>
            <modifier type="replace" value="4+*" field="name" arg="5+"/>
          </modifiers>
          <conditionGroups>
            <conditionGroup type="or">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="parent" childId="2b54-9305-b1dd-a202" shared="true" includeChildSelections="true" childName="Mark of Tzeentch"/>
                <condition type="atLeast" value="1" field="selections" scope="root-entry" childId="f821-a98e-15ee-10e8" shared="true" includeChildSelections="true" childName="Icon of Tzeentch"/>
              </conditions>
            </conditionGroup>
          </conditionGroups>
        </modifierGroup>
      </modifierGroups>
    </rule>
    <rule name="Invulnerable Save (4+)" id="75d7-0aa6-8c45-0684" hidden="false">
      <description>This model has an Invulnerable Save of 4+.</description>
      <modifierGroups>
        <modifierGroup type="and">
          <modifiers>
            <modifier type="replace" value="3+ (from Mark of Tzeentch)." field="description" arg="4+"/>
            <modifier type="replace" value="3+*" field="name" arg="4+"/>
          </modifiers>
          <conditionGroups>
            <conditionGroup type="or">
