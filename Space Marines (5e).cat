      <rules>
        <rule name="Venerable" id="vend-0001-rule-0001" hidden="false">
          <description>If a Venerable Dreadnought suffers a glancing or penetrating hit, you can ask your opponent to re-roll the result rolled on the vehicle damage chart. You must accept the result of the second roll, even if it is worse than the first.</description>
        </rule>
      </rules>
