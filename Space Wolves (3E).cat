      <rules>
        <rule name="Operate Behind Enemy Lines" id="c52c-2897-c17a-b36e" hidden="false">
          <description>Instead of being set up normally, one unit of Space Wolf Scouts (and their Wolf Guard leader if they have one) can be sent out ahead of the army to operate behind enemy lines. If you decide to use this option then the Scout unit must be kept in reserve, even in scenarios that don&apos;t normally allow reserves to be used. When the Scouts turn up, they must enter play from the table edge that the opposing side&apos;s reserves enter from or retreat towards, rather than from their own side&apos;s table edge. If the opponent doesn&apos;t have a table edge then roll randomly to see which edge they enter from.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink name="Infiltrate" id="147b-a2b5-11e1-68c0" hidden="false" type="rule" targetId="c27d-09d4-6a09-1bcd"/>
        <infoLink name="Move Through Cover" id="2dc0-549a-057b-9c94" hidden="false" type="rule" targetId="b24c-f56b-5867-01e7"/>
      </infoLinks>
    </selectionEntry>
    <selectionEntry type="unit" import="true" name="Wolf Guard" hidden="false" id="767c-3cb5-1301-78e8" subType="unit-group">
      <categoryLinks>
