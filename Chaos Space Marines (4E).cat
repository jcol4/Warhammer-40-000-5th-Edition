    <selectionEntryGroup name="Mark of Chaos" id="3cea-4814-be0e-6d97" hidden="false">
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Mark of Khorne" hidden="false" id="a886-8c94-f3d4-d8c0">
          <profiles>
            <profile name="Mark of Khorne" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="5f69-4e6d-bf9e-e3a3">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Models with the Mark of Khorne gain +1 Attack and the Fearless and Blood Frenzy special rules.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="10"/>
          </costs>
          <modifiers>
            <modifier type="set" value="true" field="hidden">
              <conditions>
                <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="e037-0917-6932-52b9" shared="true" childName="Chaos Sorceror"/>
              </conditions>
            </modifier>
            <modifier type="increment" value="1" field="4.123232344415441e+21" affects="self.entries.profiles.Unit" scope="parent"/>
          </modifiers>
          <rules>
            <rule name="Fearless" id="a886-fear-rule-0001" hidden="false">
              <description>The unit automatically passes all Morale checks, Pinning tests, and Regroup tests.</description>
            </rule>
            <rule name="Blood Frenzy" id="a886-blfr-rule-0001" hidden="false">
              <description>At the start of the Movement phase, if any enemy unit is within range and visible, this unit must declare a charge against it. Roll a D6: on a 1 or 2, the unit may not shoot this turn and must move an additional D6&quot; directly towards the nearest visible enemy unit. This unit always performs a Sweeping Advance when it wins an assault.</description>
            </rule>
          </rules>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Mark of Tzeentch" hidden="false" id="2b54-9305-b1dd-a202">
          <profiles>
            <profile name="Mark of Tzeentch" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="0a00-ecda-6724-d66b">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Characters and Aspiring Champions with this mark become Sorcerers and always pass Psychic tests. Units with this mark gain Fearless and a 5+ Invulnerable Save.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="10"/>
          </costs>
          <rules>
            <rule name="Fearless" id="2b54-fear-rule-0001" hidden="false">
              <description>The unit automatically passes all Morale checks, Pinning tests, and Regroup tests.</description>
            </rule>
            <rule name="Invulnerable Save (5+)" id="4a39-3ba3-ef64-ea73" hidden="false">
              <description>This unit has an Invulnerable Save of 5+.</description>
            </rule>
          </rules>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Mark of Slaanesh" hidden="false" id="9286-dbf9-b296-edf2">
          <profiles>
            <profile name="Mark of Slaanesh" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="243b-68bc-f2e9-64a5">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Models with the Mark of Slaanesh gain the Fearless and Scream special rules. Enemy units suffer -1 Initiative while in base contact with this unit during the Assault phase.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="10"/>
          </costs>
          <rules>
            <rule name="Fearless" id="9286-fear-rule-0001" hidden="false">
              <description>The unit automatically passes all Morale checks, Pinning tests, and Regroup tests.</description>
            </rule>
            <rule name="Scream" id="9286-scrm-rule-0001" hidden="false">
              <description>Enemy units in base contact with this unit suffer -1 Initiative during the Assault phase.</description>
            </rule>
          </rules>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Mark of Nurgle" hidden="false" id="4150-9784-b68a-93c4">
          <profiles>
            <profile name="Mark of Nurgle" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="1509-40c3-7bf8-8f32">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Models with the Mark of Nurgle gain +1 Toughness and the Fearless and True Grit special rules. Like the Toughness bonus from riding a Bike, this mark does not affect the model&apos;s Toughness for Instant Death purposes.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="10"/>
          </costs>
          <modifiers>
            <modifier type="set" value="4 (5)" field="5.423232344415441e+21" affects="self.entries.profiles.Unit" scope="parent">
              <conditionGroups>
                <conditionGroup type="and">
                  <conditions>
                    <condition type="notInstanceOf" value="1" field="selections" scope="ancestor" childId="1dcc-8d0c-7819-2bd4" shared="true" childName="Daemon Prince"/>
                  </conditions>
                </conditionGroup>
              </conditionGroups>
            </modifier>
            <modifier type="set" value="5 (6)" field="5.423232344415441e+21" affects="self.entries.profiles.Unit" scope="parent">
              <conditionGroups>
                <conditionGroup type="or">
                  <conditions>
                    <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="1dcc-8d0c-7819-2bd4" shared="true" childName="Daemon Prince"/>
                  </conditions>
                </conditionGroup>
              </conditionGroups>
            </modifier>
          </modifiers>
          <rules>
            <rule name="Fearless" id="4150-fear-rule-0001" hidden="false">
              <description>The unit automatically passes all Morale checks, Pinning tests, and Regroup tests.</description>
            </rule>
            <rule name="True Grit" id="4150-tgrt-rule-0001" hidden="false">
              <description>Models with True Grit may fire their ranged weapons at full rate of fire in the Shooting phase and still count as charging when they assault in the same turn.</description>
            </rule>
          </rules>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Mark of Chaos Undivided" hidden="false" id="4e2a-undv-mark-0001">
          <profiles>
            <profile name="Mark of Chaos Undivided" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="4e2a-undv-prof-0001">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The character or unit may re-roll any failed Morale checks. Only one re-roll may be made and the new result is final. All members of the unit must have the Mark of Chaos Undivided, or be followers or Steeds of a model that has it.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="5"/>
          </costs>
          <rules>
            <rule name="Mark of Chaos Undivided" id="4e2a-undv-rule-0001" hidden="false">
              <description>May re-roll any failed Morale checks. Only one re-roll may be made and the new result is final. All members of the unit must have the Mark of Chaos Undivided, or be followers or Steeds of a model that has it.</description>
            </rule>
          </rules>
        </selectionEntry>
      </selectionEntries>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="6216-702a-aea8-9e1e" includeChildSelections="false" automatic="true"/>
        <constraint type="max" value="1" field="selections" scope="root-entry" shared="true" id="9dc8-bbee-bc23-199d" includeChildSelections="true" automatic="false"/>
      </constraints>
      <modifiers>
        <modifier type="set" value="true" field="hidden">
          <conditionGroups>
            <conditionGroup type="and">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="root-entry" childId="3cea-4814-be0e-6d97" shared="true" includeChildSelections="true" childName="Mark of Chaos"/>
                <condition type="equalTo" value="0" field="selections" scope="parent" childId="3cea-4814-be0e-6d97" shared="true" childName="Mark of Chaos"/>
              </conditions>
            </conditionGroup>
          </conditionGroups>
        </modifier>
      </modifiers>
    </selectionEntryGroup>
    <selectionEntryGroup name="Vehicle Upgrades" id="c929-cd07-41ee-62fb" hidden="false">
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Daemonic Posession" hidden="false" id="4031-d754-58b0-8a26">
          <profiles>
            <profile name="Daemonic Posession" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="0f05-dbcf-e6fb-193a">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The vehicle ignores Shaken and Stunned results altogether (though transported passengers are affected normally), but its Ballistic Skill is reduced to 3.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
      <entryLinks>
        <entryLink import="true" name="Dozer Blade" hidden="false" id="0472-93c2-c490-5274" type="selectionEntry" targetId="99b1-d567-bb76-a744"/>
