        <selectionEntry type="upgrade" import="true" name="Armour of Shrieking Souls" hidden="false" id="c6f3-735c-7b70-76e7" sortIndex="4">
          <profiles>
            <profile name="Armour of Shrieking Souls" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="8697-8a04-2bc7-4ac3">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">For each successful Armour Save or Invulnerable Save Lucius makes in close combat, the unit causing the wound immediately suffers a Strength 4 hit that ignores armour saves.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="bab7-26aa-441e-7f16-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="bab7-26aa-441e-7f16-max" includeChildSelections="false"/>
          </constraints>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Lash of Torment" hidden="false" id="e8c2-e9f1-9d7d-9ff4" sortIndex="2">
          <profiles>
            <profile name="Lash of Torment" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="28df-2402-1400-68fd">
              <characteristics>
                <characteristic name="Details" typeId="acf3-d214-6e51-29fe">The Lash of Torment counts as a close combat weapon that reduces the Attacks of any model in base contact with Lucius by 1 (to a minimum of 1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
