            <selectionEntryGroup name="Command Squad Upgrades" id="3ea1-771b-eb0d-29c6" hidden="true" flatten="true">
              <selectionEntries>
                <selectionEntry type="upgrade" import="true" name="Standard Bearer" hidden="false" id="274e-cb54-ab44-7aef">
                  <selectionEntries>
                    <selectionEntry type="upgrade" import="true" name="Deathwing Company Standard" hidden="false" id="66ed-a27f-aaa4-2138">
                      <constraints>
                        <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="9b67-d439-3af3-5558-min" includeChildSelections="false"/>
                        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="9b67-d439-3af3-5558-max" includeChildSelections="false"/>
                      </constraints>
                      <profiles>
                        <profile name="Deathwing Company Standard" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="2c6b-17a5-60bb-b296">
                          <characteristics>
                            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Any Dark Angels unit within 12&quot; of the standard may re-roll any failed Morale and Pinning tests. In addition, all models win the standard bearer&apos;s unit adds 1 to their Attacks characteristic.</characteristic>
                          </characteristics>
                        </profile>
                      </profiles>
                      <modifiers>
                        <modifier type="increment" value="1" field="4.123232344415441e+21" affects="self.entries.profiles.Unit" scope="root-entry"/>
                      </modifiers>
                    </selectionEntry>
                  </selectionEntries>
                  <constraints>
                    <constraint type="max" value="1" field="selections" scope="force" shared="true" id="9b08-5598-a693-04e0" includeChildSelections="true"/>
                  </constraints>
                  <costs>
                    <cost name="Points" typeId="4deb-313d-6685-f48b" value="25"/>
                  </costs>
                </selectionEntry>
                <selectionEntry type="upgrade" import="true" name="Apothecary" hidden="false" id="462d-7f0d-811e-45da">
                  <selectionEntries>
                    <selectionEntry type="upgrade" import="true" name="Narthecium &amp; Reductor" hidden="false" id="a7bf-ce43-02bb-ad03">
                      <constraints>
                        <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="bd03-42ca-79d9-37b3-min" includeChildSelections="false"/>
                        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="bd03-42ca-79d9-37b3-max" includeChildSelections="false"/>
                      </constraints>
                      <profiles>
                        <profile name="Narthecium" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="7f50-bea1-f2d7-be48">
                          <characteristics>
                            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">In order to use this equipment, the Apothecary cannot be Falling Back, Locked in close combat, or Pinned.
He may treat any friendly non-vehicle model within 6&quot; of him. Once per turn he may use his narthecium to allow a treatable model to ignore a failed Save (of any sort). It is, however, of no use against an attack that causes Instant Death or a close combat attack that ignores Armour Saves.</characteristic>
                          </characteristics>
                        </profile>
                        <profile name="Reductor" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="071b-2216-ddeb-72e2">
                          <characteristics>
                            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">In order to use this equipment, the Apothecary cannot be Falling Back, Locked in close combat, or Pinned.
He may treat any friendly non-vehicle model within 6&quot; of him. In the enemy Shooting phase, the Apothecary can use his reductor to recover the gene-seed of any treatable models that are killed within 6&quot; of him. These casualties are ignored when determining if their units have to take a Morale test for suffering 25% shooting casualties. For examaple, a unit suffers four casualties out of nine but two of them are within 6&quot; of the Apothecary, so no Morale test is taken.</characteristic>
                          </characteristics>
                        </profile>
                      </profiles>
                    </selectionEntry>
                  </selectionEntries>
                  <constraints>
                    <constraint type="max" value="1" field="selections" scope="force" shared="true" id="53ee-052c-34fc-252a" includeChildSelections="true"/>
                  </constraints>
                  <costs>
                    <cost name="Points" typeId="4deb-313d-6685-f48b" value="30"/>
                  </costs>
                </selectionEntry>
              </selectionEntries>
              <modifiers>
                <modifier type="set" value="false" field="hidden">
                  <conditions>
                    <condition type="atLeast" value="1" field="selections" scope="root-entry" childId="c58e-30b0-2c57-acc8" shared="true" childName="Command Squad" includeChildSelections="true"/>
