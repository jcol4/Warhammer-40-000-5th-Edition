    <selectionEntry type="upgrade" import="true" name="The Lion Helm" hidden="true" id="16a3-b6bd-23d3-02a9">
      <costs>
        <cost name="Points" typeId="4deb-313d-6685-f48b" value="35"/>
      </costs>
      <profiles>
        <profile name="The Lion Helm" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="a1f4-df2b-6c7c-af6c">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The Lion Helm is carried by a Helmet Bearer. It stays within 2&quot; of the character with the Lion Helm. It can not attack or be attacked.
The Lion Helm projects a force field  that provides any model (friend or foe) within 3&quot; of the Helmet Bearer with a 4+ Invulnerable save against any shooting attacks.
The effect of the Lion Helm does not extend to vehicles.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <modifiers>
        <modifier type="set" value="false" field="hidden">
          <conditionGroups>
            <conditionGroup type="and">
              <conditions>
                <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="9862-c761-5bd2-ffc7" shared="true"/>
