      </infoLinks>
      <rules>
        <rule name="Honour of the Chapter" id="chp0-hotc-rule-0001" hidden="false">
          <description>A Chaplain utterly embodies the honour of the Chapter. He, and all members of a squad he has joined, are fearless, as described in the Warhammer 40,000 rulebook.</description>
        </rule>
        <rule name="Liturgies of Battle" id="chp0-lob-rule-0001" hidden="false">
          <description>On a player turn in which he assaults, a Chaplain and all members of any squad he has joined can re-roll failed rolls to hit.</description>
        </rule>
      </rules>
