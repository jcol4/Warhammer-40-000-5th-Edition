          </constraints>
        </entryLink>
      </entryLinks>
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Drach&apos;nyen &amp; Talon of Horus" hidden="false" id="98b5-7eb4-e38e-416c" sortIndex="1">
          <profiles>
            <profile name="Drach&apos;nyen &amp; Talon of Horus" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="ce7a-a672-0c6d-c2aa">
              <characteristics>
                <characteristic name="Details" typeId="acf3-d214-6e51-29fe">The combination of these weapons means Abaddon counts as being equipped with a Daemon Weapon that doubles his Strength (to Strength 8 as shown in his profile) instead of the normal +1, and he may re-roll any failed roll to wound in close combat.

Abaddon get and additional +D6 Attacks from his Daemon Weapon</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="22b6-bf50-7160-c36a-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="22b6-bf50-7160-c36a-max" includeChildSelections="false"/>
          </constraints>
        </selectionEntry>
      </selectionEntries>
      <rules>
        <rule name="Mark of Chaos Ascendant" id="997b-279c-39bf-316f" hidden="false">
          <description>The Mark of Chaos Ascendant combines all the gifts provided by the Marks of Chaos, as well as granting Abaddon immunity to Instant Death.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink name="Fearless" id="322b-5cce-c705-524b" hidden="false" type="rule" targetId="db33-1068-512b-6958"/>
