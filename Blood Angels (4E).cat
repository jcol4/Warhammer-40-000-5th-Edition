          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="967c-62bf-dcad-c1cf" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="868c-582d-f68a-b1b0" includeChildSelections="false"/>
