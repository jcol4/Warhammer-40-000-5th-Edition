        <selectionEntry type="upgrade" import="true" name="Command Squad" hidden="true" id="c58e-30b0-2c57-acc8" sortIndex="1">
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="52a6-1765-ada0-b4f0" shared="true" childName="Master Belial of the Deathwing" includeChildSelections="true"/>
