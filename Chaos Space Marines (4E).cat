          <profiles>
            <profile name="Rod of Torment" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="16b3-ff67-ad9e-ef5a">
              <characteristics>
                <characteristic name="Details" typeId="acf3-d214-6e51-29fe">Any opposing model suffering one or more wounds from the Rod of Torment is immediately disabled by the pain and suffers Instant Death, regardless of its Toughness.</characteristic>
              </characteristics>
