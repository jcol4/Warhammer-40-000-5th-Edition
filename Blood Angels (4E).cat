                    <profile name="Exsanguinator" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="e73d-db7b-621a-d3b6">
                      <characteristics>
                        <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Once per player turn, a friendly model within 6&quot; of a model with an Exsanguinator may ignore
a failed save as long as the bearer is not Falling Back, in close combat, or Pinned. It may not be used against Instant Death or a close combat attack that ignores armor saves.</characteristic>
