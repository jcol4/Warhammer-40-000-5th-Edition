                <selectionEntry type="upgrade" import="true" name="Terminator Armour" hidden="false" id="48c4-dddc-b334-25c4" sortIndex="2">
                  <constraints>
                    <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="5fc7-b43c-4082-295e" includeChildSelections="false"/>
                    <constraint type="min" value="0" field="selections" scope="parent" shared="true" id="7e0b-f7df-1d48-9d32" automatic="true"/>
                  </constraints>
                  <profiles>
                    <profile name="Terminator Armour" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="397a-39ff-1226-ddac">
                      <characteristics>
                        <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A model wearing Terminator armour has a 2+ Armour Save and a 5+ Invulnerable Save. The wearer automatically has Terminator Honours at no additional cost.
Any model wearing Terminator armour can be teleported onto the battlefield and set up using the Deep Strike rules, but only if the mission allows for Deep Strike to be used. If the mission does not allow Deep Strike then the model must set up normally with the rest of the army.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <modifiers>
                    <modifier type="set" value="2+" field="5.361766523232344e+27" scope="root-entry" affects="self.entries.profiles.Unit"/>
                    <modifier type="set" value="5" field="4deb-313d-6685-f48b">
                      <conditions>
                        <condition type="instanceOf" value="1" field="selections" scope="parent" childId="25c7-25b6-1ff6-df6b" shared="true"/>
                      </conditions>
                    </modifier>
                    <modifier type="set" value="true" field="hidden">
                      <conditionGroups>
                        <conditionGroup type="or">
