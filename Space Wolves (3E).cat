            <profile name="Iron Wolf Amulet" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="e3d1-f16d-9484-ad55">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The iron wolf amulet has the same effect as an iron halo.
A model equipped with an iron wolf amulet gets a 4+ Invulnerable Save that may be used instead of the model&apos;s Armour Save.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
      <profiles>
        <profile name="Wolf Priest Ulrik the Slayer" typeId="556e697423232344415441232323" typeName="Unit" hidden="false" id="bf90-ce18-31e5-7729">
          <characteristics>
            <characteristic name="Unit Type" typeId="556e6974205479706523232344415441232323">Infantry, Character</characteristic>
            <characteristic name="WS" typeId="5.753232323444154e+23">6</characteristic>
            <characteristic name="BS" typeId="4.2532323234441546e+23">5</characteristic>
            <characteristic name="S" typeId="5.323232344415441e+21">4</characteristic>
            <characteristic name="T" typeId="5.423232344415441e+21">4</characteristic>
            <characteristic name="W" typeId="5.723232344415441e+21">2</characteristic>
            <characteristic name="I" typeId="4.923232344415441e+21">5</characteristic>
            <characteristic name="A" typeId="4.123232344415441e+21">4</characteristic>
            <characteristic name="LD" typeId="4c4423232344415441232323">10</characteristic>
            <characteristic name="Sv" typeId="5.361766523232344e+27">3+</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule name="Mentor" id="3183-f975-0305-6174" hidden="false">
          <description>You may pick one model in the army as having being selected by Ulrik for mentoring. This model gains +1 Weapon Skill.
You may not pick Logan Grimnar or Ragnar Blackmane for this bonus.</description>
        </rule>
      </rules>
    </selectionEntry>
