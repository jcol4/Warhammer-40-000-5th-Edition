              <selectionEntries>
                <selectionEntry type="upgrade" import="true" name="Stimulant Injector (Special Issue)" hidden="false" id="66eb-cc38-8845-55fa">
                  <profiles>
                    <profile name="Stimulant Injector (Special Issue)" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="43e7-b0cf-4ffc-1b8a">
                      <characteristics>
                        <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The stimulant inject gives the model the Feel No Pain universal special rule.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <infoLinks>
                    <infoLink name="Feel No Pain" id="92bc-1381-07ae-816a" hidden="false" type="rule" targetId="f312-bf1e-afd7-0346"/>
