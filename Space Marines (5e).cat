    <selectionEntry type="model" import="true" name="Master of Forge" hidden="false" id="mof0-0000-0000-0001" publicationId="b8b3-96de-ab2d-52b7" sortIndex="5">
      <categoryLinks>
        <categoryLink name="HQ" hidden="false" id="a100-0000-0000-0007" targetId="0d45-9523-cfd8-4efd" primary="true"/>
        <categoryLink name="Character" hidden="false" id="a100-0000-0000-0008" targetId="c918-96c1-1ff1-3df1" primary="false"/>
      </categoryLinks>
