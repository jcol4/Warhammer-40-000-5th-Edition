        <entryLink import="true" name="Terminator Command Squad" hidden="false" id="1374-b233-5ce6-a0c4" type="selectionEntry" targetId="dfad-a748-913f-6a1f" sortIndex="5"/>
      </entryLinks>
      <rules>
        <rule name="Teleport Assault" id="f792-a159-c091-01ef" hidden="false">
          <description>If an Imperial Fists army including Lysander elects to deploy its Terminators by Deep Strike, Lysander will lead the assault. Make one Reserves roll for all the Terminators in the army, re-rolling the result if desired. All Terminators will therefore arrive on the same turn, though each unit will be placed independently.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink name="And They Shall Know No Fear" id="5f59-3ff6-23d8-d157" hidden="false" type="rule" targetId="8eaf-de62-f965-125b"/>
      </infoLinks>
    </selectionEntry>
