              </repeats>
            </modifier>
            <modifier type="increment" value="1" field="fe27-9dd9-8216-754e-max">
              <repeats>
                <repeat value="1" repeats="1" field="selections" scope="force" childId="3da1-7fda-782c-538a" shared="true" roundUp="false" includeChildSelections="true" childName="Assault Squad"/>
                <repeat value="1" repeats="1" field="selections" scope="force" childId="40b5-ddbb-32d1-c354" shared="true" roundUp="false" includeChildSelections="true" childName="Honor Guard"/>
