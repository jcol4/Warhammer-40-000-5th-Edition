          </constraints>
          <profiles>
            <profile name="Dawn Blade" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="5f11-630e-a907-565b">
              <characteristics>
                <characteristic name="Details" typeId="acf3-d214-6e51-29fe">No Armour Saves may be taken from hits caused by the Dawn Blade. O&apos;Shovah rolls 2D6+5 when rolling to penetrate the armour of a vehicle.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
      <costs>
        <cost name="Points" typeId="4deb-313d-6685-f48b" value="170"/>
      </costs>
      <rules>
        <rule name="Ork Fighter" id="73d7-2905-0a62-1111" hidden="false">
          <description>Any Tau model in an army led by O&apos;Shovah have the Preferred Enemy special rule when fighting against Orks.</description>
        </rule>
        <rule name="Breakaway Faction" id="37de-4775-8be1-038b" hidden="false">
          <description>No Ethereals, Kroot, or Vespid units may be included in O&apos;Shovah&apos;s force. Crisis battlesuits count as 1+ units in the same way as Fire Warriors, and the following units count as 0-1 in an army led by O&apos;Shovah: Stealth armour, Pathfinder squads, Hammerhead, Broadside battlesuits, Sky Ray gunships &amp; Piranha skimmers.</description>
        </rule>
        <rule name="Blood Brothers" id="cd06-8eca-a8e6-6dcf" hidden="false">
          <description>Every model in Farsight&apos;s army with access to the Armoury gains a bonding knife at no additional cost.</description>
        </rule>
      </rules>
    </selectionEntry>
