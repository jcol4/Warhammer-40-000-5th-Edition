    <categoryEntry name="Dark Angel" id="9862-c761-5bd2-ffc7" hidden="false"/>
    <categoryEntry name="Death Company" id="3c1a-0f72-de9c-14e3" hidden="true">
      <modifiers>
        <modifier type="set" value="false" field="hidden">
          <conditions>
            <condition type="atLeast" value="1" field="selections" scope="force" childId="e39c-0852-74f1-402d" shared="true" includeChildSelections="true"/>
          </conditions>
        </modifier>
      </modifiers>
    </categoryEntry>
    <categoryEntry name="Dreadnought" id="5330-7b73-1fd2-d75f" hidden="false"/>
