                </selectionEntry>
                <selectionEntry type="upgrade" import="true" name="Failsafe Detonator (Special Issue)" hidden="false" id="ade1-4428-c06f-38ef">
                  <costs>
                    <cost name="Points" typeId="4deb-313d-6685-f48b" value="15"/>
                  </costs>
                  <profiles>
                    <profile name="Failsafe Detonator (Special Issue)" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="96e7-96d6-1a40-c90d">
                      <characteristics>
                        <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The failsafe detonator may be triggered if the bearer is part of a team that is forced to make a Fall Back move having lost an assault.
The team is moved as normal, but the character stays where he is and the enemy may not make a Sweeping Advance. Once his team has moved, and before Pile In moves, the character activates the detonator - place the Large Blast marker centered on the character, and roll for partial hits on other models as normal. Every model hit takes a single Strength 8, AP - hit, and the character is removed as a casualty. The enemy may not Consolidate. Note that the enemy unit need not take a Morale check should this attack inflict 25%  casualties, as it occurs outside the normal game sequence i which such checks are required.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <constraints>
                    <constraint type="max" value="1" field="selections" scope="force" shared="true" id="7081-ba5c-ab3d-e17c" includeChildSelections="true"/>
                  </constraints>
                </selectionEntry>
                <selectionEntry type="upgrade" import="true" name="Iridium Armour (Special Issue)" hidden="false" id="d006-908a-ac01-25cc">
                  <costs>
                    <cost name="Points" typeId="4deb-313d-6685-f48b" value="20"/>
                  </costs>
                  <profiles>
                    <profile name="Iridium Armour (Special Issue)" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="2df2-0d9a-3afe-77aa">
                      <characteristics>
                        <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Iridium armour increases the model&apos;s Armour Save to 2+, but the addition 6&quot; move in the Assault phase is reduced to D6&quot;.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <modifiers>
                    <modifier type="set" value="2+" field="5.361766523232344e+27" affects="self.entries.964c-f498-e9fd-02ea.profiles.Unit" scope="parent"/>
                    <modifier type="set" value="2+" field="5.361766523232344e+27" affects="self.entries.9d2b-9fc6-d27a-00f5.profiles.Unit" scope="parent"/>
                  </modifiers>
