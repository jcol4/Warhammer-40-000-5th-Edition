    <selectionEntry type="upgrade" import="true" name="Space Marine Bike" hidden="false" id="da0f-af82-52b0-763e">
      <profiles>
        <profile name="Space Marine Bike" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="5894-2942-8bd2-7f7d">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Models with Space Marine Bikes follow all rules for Bikes and are equipped with twin-linked bolters.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <modifiers>
        <modifier type="append" value="(5)" field="5.423232344415441e+21" scope="parent" affects="self.entries.profiles.Unit" join=" " position="3"/>
        <modifier type="replace" value="Bike" field="556e6974205479706523232344415441232323" affects="self.entries.profiles.Unit" scope="parent" arg="Infantry"/>
      </modifiers>
      <infoLinks>
        <infoLink name="Bolter" id="362b-d917-c294-5915" hidden="false" type="profile" targetId="fa34-07ff-1a5d-fe9f">
          <modifiers>
            <modifier type="set" value="Twin-linked Bolter" field="name"/>
