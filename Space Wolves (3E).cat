      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="The Axe Morkai" hidden="false" id="4cd9-46df-692b-ab59" sortIndex="1">
          <profiles>
            <profile name="The Axe Morkai" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="3e28-a189-a54f-64d1">
              <characteristics>
                <characteristic name="Details" typeId="acf3-d214-6e51-29fe">Morkai is a master crafted power weapon that Logan can choose to use either as a frost blade or as a power fist. He can choose to split his attacks between the two weapon types.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="26e0-16e3-bad8-acc7-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="26e0-16e3-bad8-acc7-max" includeChildSelections="false"/>
          </constraints>
        </selectionEntry>
      </selectionEntries>
      <rules>
        <rule name="Legendary Leader" id="b4dc-9d96-a34c-f454" hidden="false">
          <description>Once per battle Logan can call on those nearby to redouble their efforts and attack with all of their might. When he does this, all friendly models within 12&quot; of Logan, whether they belong to the Space Wolves or not, get a +1 Attack bonus for the rest of the turn. Note that Logan can make his call during the opponent&apos;s turn if desired.</description>
        </rule>
      </rules>
