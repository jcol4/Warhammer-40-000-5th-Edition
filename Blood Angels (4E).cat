          </modifiers>
          <rules>
            <rule name="Venerable Dreadnought" id="3610-466b-44d4-f352" hidden="false">
              <description>Venerable Dreadnought are extremely hard to kill and whenever they suffer a glancing or penetrating hit you may ask your opponent to re-roll the result on the Vehicle Damage tables. However, you much accept the second result, even if it is worse.</description>
            </rule>
          </rules>
