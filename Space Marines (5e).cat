        <profile name="Land Speeder Storm" typeId="56656869636c6523232344415441232323" typeName="Vehicle" hidden="false" id="lss-veh-prof-0001">
          <characteristics>
            <characteristic name="BS" typeId="a6a5-1595-da9e-6155">3</characteristic>
            <characteristic name="Front" typeId="46726f6e7423232344415441232323">10</characteristic>
            <characteristic name="Side" typeId="5.369646523232344e+27">10</characteristic>
            <characteristic name="Rear" typeId="5.265617223232345e+27">10</characteristic>
            <characteristic name="Type" typeId="5.479706523232345e+27">Vehicle (Fast, Skimmer)</characteristic>
          </characteristics>
        </profile>
        <profile name="Land Speeder Storm" typeId="307d-047f-ca13-706b" typeName="Transport" hidden="false" id="lss-trans-prof-0001">
          <characteristics>
            <characteristic name="Capacity" typeId="8285-4205-b6cd-8473">5 models (Scouts only)</characteristic>
            <characteristic name="Fire Points" typeId="b270-a7f9-22b2-3702">0</characteristic>
            <characteristic name="Access Points" typeId="d17b-0342-b1dc-b8e7">One at the rear</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule name="Cerberus Launcher" id="lss-cerb-rule-0001" hidden="false">
          <description>If a Scout unit charges into combat on the same turn as it disembarks from the Land Speeder, any enemy units that the Scouts assault have their Leadership reduced by 2 for the duration of that assault phase.</description>
        </rule>
        <rule name="Jamming Beacon" id="lss-jamb-rule-0001" hidden="false">
          <description>Teleport homers, Chaos Icons and similar wargear items that prevent deep strike scatter do not function within 6&quot; of a Land Speeder Storm. In addition, enemies wishing to deep strike onto the board within 6&quot; of a Land Speeder Storm scatter 4D6&quot; rather than 2D6&quot;.</description>
        </rule>
      </rules>
      <selectionEntryGroups>
        <selectionEntryGroup name="Primary Weapon" id="lss-pw-grp" hidden="false" collective="false" import="true" defaultSelectionEntryId="lss-pw-hb-el">
