  <sharedRules>
    <rule name="Rites of Battle" id="2443-287f-f8df-ffa4" hidden="false">
      <description>If a Space Marine Commander is on the table then all other Space Marine squads may used his Leadership for Morale, Pinning, or Leadership tests (but not Psychic tests).</description>
    </rule>
    <rule name="Honour of the Chapter" id="9cb2-4889-4b6c-190d" hidden="false">
      <description>Chaplains embody the honour of their Chapter. They, and all members of any Space Marine squad they have joined, lead, or attached to are Fearless.</description>
    </rule>
    <rule name="Litanies of Hate" id="99d7-eaaa-fb97-4d39" hidden="false">
      <description>On a player turn in which he charges into close combat, a Chaplain, and all members of any Space Marine squad he has joined, leads, or is attached to may re-roll failed rolls to hit.</description>
    </rule>
    <rule name="Teleport" id="7ca1-8422-a7a4-cbbc" hidden="false">
      <description>A Terminator Squad may start the game in Reserve and arrive using the Deep Strike special rule, even if it is not part of the mission being played.</description>
    </rule>
  </sharedRules>
  <categoryEntries>
