      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Psychic Hood" hidden="false" id="b541-0bd8-f21f-61d2" sortIndex="3">
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="8828-4297-897c-725d" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="74f0-cb1e-4e27-a81d" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="Psychic Hood" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="4345-444f-c517-8f70">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A psychic hoods is arcane construction of psychically attuned crystals that allow a Space Marine Librarian to nullify an opposing psyker&apos;s power. Declare that you&apos;ll use the psychic hood after an opponent has successfully made a Psychic test, but before they have used the power. Each player then rolls a D6 and adds their model&apos;s Leadership value to the score. If the Space Marine Librarian beats the opposing model&apos;s score then the psychic power is nullified and may not be used that turn. If the opposing model&apos;s score is higher, it may use its psychic power as normal. The psychic hood may be used each time an enemy model uses a psychic power. Only one Librarian may use his psychic hood against a single use of a psychic power.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
      <selectionEntryGroups>
