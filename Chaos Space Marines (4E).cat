    <selectionEntry type="upgrade" import="true" name="Enhanced Warriors" hidden="true" id="ec23-5ba9-11ce-601c">
      <rules>
        <rule name="Enhanced Warriors" id="aee0-900c-d2bf-dc7a" hidden="false">
          <description>At the start of the battle, after both sides have set up but before the first turn, roll a D6 for each enhanced squad and consult the table below.

D1 - Berserk Rage!: Make an armour save for each warrior, removing any who fail. Survivors are Fearless and at +1 Strength for the remainder of the game.
D2-5 - Stable: The enhanced warriors are Fearless and have +1 Strength for the entire game.
D6 - Created a Monster: The warriors are Fearless and add +2 to their Strength for the entire game. At the end of every owning player&apos;s turn, one of the squads members is removed as a casualty (owner&apos;s choice).</description>
        </rule>
      </rules>
      <modifiers>
        <modifier type="increment" value="3" field="4deb-313d-6685-f48b">
          <repeats>
            <repeat value="1" repeats="1" field="selections" scope="root-entry" childId="model" shared="true" roundUp="false" childName="model"/>
          </repeats>
        </modifier>
      </modifiers>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="4f50-1337-b329-264f" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
  </sharedSelectionEntries>
