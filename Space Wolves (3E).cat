          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Chooser of the Slain" hidden="true" id="f19b-6e76-81b6-4804">
              <modifiers>
                <modifier type="set" value="false" field="hidden">
                  <conditions>
                    <condition type="instanceOf" value="1" field="selections" scope="parent" childId="e7b3-4619-9484-a9a7" shared="true"/>
                  </conditions>
                </modifier>
              </modifiers>
              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="10"/>
              </costs>
              <profiles>
                <profile name="Chooser of the Slain" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="1764-0659-15a2-ed4b">
                  <characteristics>
                    <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Enemy Infiltrators may not set up using their special rules against a Space Wolves army that includes a Rune Priest with a Chooser of the Slain unless they first roll a 4+ on a D6 (roll separately for each unit). In addition, Rune Priests that have a Chooser of the Slain count as having an additional close combat weapon in close combat, although this modifier does not apply if the Rune Priest already has an additional hand weapon.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="a7fe-d88f-f962-b719" includeChildSelections="false"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Fang of Morkai" hidden="true" id="55fc-4103-2c75-6e19">
              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="5"/>
              </costs>
              <modifiers>
                <modifier type="set" value="false" field="hidden">
                  <conditionGroups>
                    <conditionGroup type="and">
                      <conditions>
                        <condition type="equalTo" value="0" field="selections" scope="parent" childId="48c4-dddc-b334-25c4" shared="true"/>
                        <condition type="instanceOf" value="1" field="selections" scope="parent" childId="e7b3-4619-9484-a9a7" shared="true"/>
                      </conditions>
                    </conditionGroup>
                  </conditionGroups>
                </modifier>
              </modifiers>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="e55e-9f7d-4843-f304" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="Fang of Morkai" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="4a17-8963-8fc0-5542">
                  <characteristics>
                    <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A Fang of Morkai has the same effect as a Reductor.
In order to use this equipment, the Wolf Priest cannot be Falling Back, Locked in close combat, or Pinned.
He may treat any friendly non-vehicle model within 6&quot; of him. In the enemy Shooting phase, the Apothecary can use his reductor to recover the gene-seed of any treatable models that are killed within 6&quot; of him. These casualties are ignored when determining if their units have to take a Morale test for suffering 25% shooting casualties. For examaple, a unit suffers four casualties out of nine but two of them are within 6&quot; of the Wolf Priest, so no Morale test is taken.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Mark of the Wulfen" hidden="true" id="c6b3-67e1-40e7-62ab">
              <modifiers>
                <modifier type="set" value="false" field="hidden">
                  <conditionGroups>
                    <conditionGroup type="and">
                      <conditions>
                        <condition type="instanceOf" value="1" field="selections" scope="parent" childId="25c7-25b6-1ff6-df6b" shared="true"/>
                        <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="767c-3cb5-1301-78e8" shared="true"/>
                      </conditions>
                    </conditionGroup>
                  </conditionGroups>
                </modifier>
              </modifiers>
              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="10"/>
              </costs>
              <profiles>
                <profile name="Mark of the Wulfen" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="c351-9867-a00a-134c">
                  <characteristics>
                    <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The Mark of the Wulfen is limited to a single Wolf Guard model in each army. It can be shown by either painting facial tattoos on the model, or converting the model to show it in its beastlike state. A Wolf Guard bearing the Mark is treated as an Independent Character and must remain on his own at all time. He is allowed to be near another unit but he cannot join it. A model bearing the Mark of the Wulfen may not be given Terminator Armour, a jump pack, nor may he ride a Space Marine bike.


A model bearing the Mark of the Wulfen explodes into a wild bestial fury in close combat. He undergoes a physical transformation into a wild beast-like creature. Such is his savagery in combat that he receives D3 additional attacks and always strikes his foes on a roll of 3+ whatever their Weapon Skill. On the other hand, his complete disregard fore his own safety means that opponents will always hit him in close combat on a D6 roll of 3+, whatever their Weapon Skill. Finally, a character bearing the Mark of the Wulfen simply does not know the meaning of fear and will automatically pass all Morale and Pinning test and may ignore opposing troops or weapons that can cause an opponent to automatically fall back.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="8c28-e77e-3c99-5966" includeChildSelections="false"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Master Crafted Weapon" hidden="false" id="62d5-3d5a-2744-9776">
              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="15"/>
              </costs>
              <infoLinks>
                <infoLink name="Master-crafted" id="40d6-dfd1-450b-b2fa" hidden="false" type="rule" targetId="55c5-f2b8-a4a7-b734"/>
              </infoLinks>
              <modifiers>
                <modifier type="set" value="10" field="4deb-313d-6685-f48b">
                  <conditions>
                    <condition type="instanceOf" value="1" field="selections" scope="parent" childId="767c-3cb5-1301-78e8" shared="true"/>
                  </conditions>
                </modifier>
              </modifiers>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Servo-arm" hidden="true" id="c0ae-1d3d-d3fc-59c3">
              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="30"/>
              </costs>
              <modifiers>
                <modifier type="set" value="false" field="hidden">
                  <conditionGroups>
                    <conditionGroup type="and">
                      <conditions>
                        <condition type="instanceOf" value="1" field="selections" scope="parent" childId="0da6-d69d-ca7c-c805" shared="true"/>
                        <condition type="equalTo" value="0" field="selections" scope="parent" childId="48c4-dddc-b334-25c4" shared="true"/>
                      </conditions>
                    </conditionGroup>
                  </conditionGroups>
                </modifier>
              </modifiers>
              <profiles>
                <profile name="Servo-arm" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="8767-8f5b-64ce-1206">
                  <characteristics>
                    <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Many Techmarines are equipped with powerful augmetic servo-arms that can be use to carry out hasty battlefield repairs (see Blessing of the Omnissiah rule). The servo-arm grants the Techmarine and additional close combat attack, counting as a power fist.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="a338-6a47-af2e-77da" includeChildSelections="false"/>
              </constraints>
              <infoLinks>
                <infoLink name="Power Fist" id="d18c-187a-92e0-8d82" hidden="false" type="profile" targetId="180c-c683-5834-19cc">
                  <modifiers>
                    <modifier type="set" value="Servo-arm (Power Fist)" field="name"/>
                  </modifiers>
                </infoLink>
              </infoLinks>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Healing potions &amp; balms" hidden="true" id="66ce-822b-24e0-e4eb">
              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="25"/>
              </costs>
              <modifiers>
                <modifier type="set" value="false" field="hidden">
                  <conditionGroups>
                    <conditionGroup type="and">
                      <conditions>
                        <condition type="instanceOf" value="1" field="selections" scope="parent" childId="c2f0-445c-dee4-a4d9" shared="true"/>
                        <condition type="equalTo" value="0" field="selections" scope="parent" childId="48c4-dddc-b334-25c4" shared="true"/>
                      </conditions>
                    </conditionGroup>
                  </conditionGroups>
                </modifier>
              </modifiers>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="d329-7b5b-59fa-19d0" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="Healing potions &amp; balms" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="36b3-dcb2-2d1f-735d">
                  <characteristics>
                    <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">If a Wolf Priest equipped with healing potions and balms joins a unit, you may ignore the first failed saving throw each turn for the unit. The potions will not work on a model that has suffered Instant Death or that has been hit by a weapon that allows no save. It may not be used if the Wolf Priest is in base contact with an enemy model. The Wolf Priest cannot use the potions and balms on himself.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Runic Charm" hidden="false" id="0e16-299c-32b4-0f0b">
              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="10"/>
              </costs>
              <modifiers>
                <modifier type="set" value="5" field="4deb-313d-6685-f48b">
                  <conditions>
                    <condition type="instanceOf" value="1" field="selections" scope="parent" childId="767c-3cb5-1301-78e8" shared="true"/>
                  </conditions>
                </modifier>
              </modifiers>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="1ef1-1697-4bc3-447e" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="Runic Charm" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="35d1-a0ad-70c1-3ac8">
                  <characteristics>
                    <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A model protected by a runic charm may re-roll one failed Armour Saving throw per battle.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Wolf Helm of Russ" hidden="false" id="f0a9-c353-f52f-61f8">
              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="40"/>
              </costs>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="0ce9-bef4-35d6-13d3" includeChildSelections="false"/>
                <constraint type="max" value="1" field="selections" scope="force" shared="true" id="0973-9fa8-7770-db93" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="Wolf Helm of Russ" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="0260-64d8-c124-e5a3">
                  <characteristics>
                    <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">The Wolf Helm has the same effect as a holy relic.
A model wearing the Wolf Helm may use it once per battle at any point. On that turn, all Space Wolves within 2D6&quot; get a +1 Attack bonus for the rest of that turn. The Helm may be revealed in an opposing player&apos;s turn if you wish.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <modifiers>
                <modifier type="set" value="true" field="hidden">
                  <conditions>
                    <condition type="instanceOf" value="1" field="selections" scope="parent" childId="25c7-25b6-1ff6-df6b" shared="true"/>
                  </conditions>
                </modifier>
              </modifiers>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Wolf Totem" hidden="true" id="b5a8-1d2f-79e2-a595">
              <profiles>
                <profile name="Wolf Totem" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="b069-82bf-645d-b399">
                  <characteristics>
                    <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A wolf totem has the same effect as a sacred standard.
The wolf totem adds +1 to the Space Wolf combat resolution score of any assault that takes place within 6&quot; of the wolf totem.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="d178-18c5-07dc-d643" includeChildSelections="false"/>
                <constraint type="max" value="1" field="selections" scope="force" shared="true" id="c081-c4d4-83c8-8c78" includeChildSelections="true"/>
              </constraints>
              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="20"/>
              </costs>
              <modifiers>
                <modifier type="set" value="false" field="hidden">
                  <conditions>
                    <condition type="instanceOf" value="1" field="selections" scope="parent" childId="cc2b-5ed7-8b70-1ee4" shared="true"/>
                  </conditions>
                </modifier>
              </modifiers>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Wolf Tooth Necklace" hidden="false" id="65d4-273a-f691-5002">
              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="10"/>
              </costs>
              <profiles>
                <profile name="Wolf Tooth Necklace" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="cf9d-4b3b-b2a9-01c2">
                  <characteristics>
                    <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Models with a wolf tooth necklace always hit on a 3+ in close combat, even against opponents whose Weapon Skill is equal to or higher than their own.
A wolf tooth necklace has no effect on enemy vehicles without a Weapon Skill characteristic.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="ac0a-fa41-fcc4-5bff" includeChildSelections="false"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Wolf Tail Talisman" hidden="false" id="a3ba-38f7-46cd-7a06">
              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="1"/>
              </costs>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="d449-bc07-1174-79d5" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="Wolf Tail Talisman" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="8cc4-db43-2ffb-49c8">
                  <characteristics>
                    <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A model protected by a wolf tail talisman is not affected by enemy psychic powers on a D6 roll of 6+.  The power still takes effect, but any character that makes his save will be unaffected.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <modifiers>
                <modifier type="set" value="true" field="hidden">
                  <conditions>
                    <condition type="atLeast" value="1" field="selections" scope="parent" childId="48c4-dddc-b334-25c4" shared="true"/>
                  </conditions>
                </modifier>
              </modifiers>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Wolf Pelt" hidden="false" id="a7a9-e2d2-5999-7592">
              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="3"/>
              </costs>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="abd3-b38b-539b-50b8" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="Wolf Pelt" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="e09f-78a5-37bf-e416">
                  <characteristics>
                    <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A model with a Wolf Pelt receives a +1 Attack bonus when they use the Counter-Attack special rule.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Great Company Banner" hidden="true" id="124d-60fb-5e7a-e03b">
              <costs>
                <cost name="Points" typeId="4deb-313d-6685-f48b" value="60"/>
              </costs>
              <profiles>
                <profile name="Great Company Banner" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="5412-5997-5a2a-70a0">
                  <characteristics>
                    <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Only a Wolf Guard Champion in the Wolf Lord&apos;s bodyguard may carry a Great Banner. The banner follows the same rules as a Chapter Banner.
Any Space Wolf unit with a model within 12&quot; of the banner may re-roll failed Morale checks. In addition, if an enemy model charges and contacts the unit containing the banner, all members of the unit gain the Counter-Attack ability and will have +1 attack until the end of the turn.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="27ed-b53e-07b8-8402" includeChildSelections="false"/>
                <constraint type="max" value="1" field="selections" scope="force" shared="true" id="8656-c76e-885e-4248" includeChildSelections="false"/>
              </constraints>
