        <entryLink import="true" name="Cenobyte Servitor" hidden="false" id="577b-3ee5-a544-6369" type="selectionEntry" targetId="7bf1-754c-52c5-717c" sortIndex="6">
          <constraints>
            <constraint type="min" value="3" field="selections" scope="parent" shared="true" id="da1f-74a5-6aa6-306d-min" includeChildSelections="false" automatic="true"/>
            <constraint type="max" value="3" field="selections" scope="parent" shared="true" id="da1f-74a5-6aa6-306d-max" includeChildSelections="false" automatic="true"/>
          </constraints>
          <rules>
            <rule name="Cenobyte Retinue" id="deca-832c-abea-398e" hidden="false">
              <description>Grimaldus leads three Cenobyte Servitors that carry the last surviving relics of Hive Helsreach&apos;s Temple of the Emperor Ascendant. These follow all the normal rules for Cenobyte Servitors and, so long as at least one is alive, Grimaldus counts as having a holy relic (note that this does not exclude the Standard Bearer in his Reclusiam Command Squad from also carrying a holy relic).</description>
            </rule>
          </rules>
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="0"/>
          </costs>
        </entryLink>
      </entryLinks>
      <profiles>
        <profile name="Chaplain Grimaldus, Hero of Helsreach" typeId="556e697423232344415441232323" typeName="Unit" hidden="false" id="6b54-ee7c-3dec-e91d">
          <characteristics>
            <characteristic name="Unit Type" typeId="556e6974205479706523232344415441232323">Infantry, Character</characteristic>
            <characteristic name="WS" typeId="5.753232323444154e+23">5</characteristic>
            <characteristic name="BS" typeId="4.2532323234441546e+23">5</characteristic>
            <characteristic name="S" typeId="5.323232344415441e+21">4</characteristic>
            <characteristic name="T" typeId="5.423232344415441e+21">4</characteristic>
            <characteristic name="W" typeId="5.723232344415441e+21">2</characteristic>
            <characteristic name="I" typeId="4.923232344415441e+21">5</characteristic>
