                      <costs>
                        <cost name="Points" typeId="4deb-313d-6685-f48b" value="5"/>
                      </costs>
                      <profiles>
                        <profile name="Sacred Standard" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="d19e-8255-d892-c8bc">
                          <characteristics>
                            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">All units with a model within 12&quot; of the Sacred Standard are Fearless.</characteristic>
                          </characteristics>
                        </profile>
                      </profiles>
                      <infoLinks>
                        <infoLink name="Fearless" id="f50c-a70e-f286-1673" hidden="false" type="rule" targetId="db33-1068-512b-6958"/>
