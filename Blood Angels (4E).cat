            <characteristic name="LD" typeId="4c4423232344415441232323">10</characteristic>
            <characteristic name="Sv" typeId="5.361766523232344e+27">2+</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink name="HQ" hidden="false" id="8f07-9e58-adae-2f58" targetId="0d45-9523-cfd8-4efd" primary="true"/>
        <categoryLink name="Character" hidden="false" id="00af-3842-6a6b-5cf1" targetId="c918-96c1-1ff1-3df1" primary="false"/>
      </categoryLinks>
      <rules>
        <rule name="The Lord of Death" id="1055-0fc1-d9dc-35ab" hidden="false">
          <description>Mephiston has all three Blood Angels Psychic Powers (see below) and can use each one of them and his
Force Weapon once each player turn, rather than being limited as are other Librarians. He may not use the same power more than once per turn.</description>
        </rule>
      </rules>
      <entryLinks>
        <entryLink import="true" name="Plasma Pistol" hidden="false" id="3d52-a2b6-9bdf-bf28" type="selectionEntry" targetId="43f8-0d25-b271-4d6c" sortIndex="1">
