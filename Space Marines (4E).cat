        <entryLink import="true" name="Krak Grenades" hidden="false" id="3ff2-2ee7-69c9-1583" type="selectionEntry" targetId="f95f-36b5-33b7-c0f3">
          <rules>
            <rule name="Krak Grenades" id="722c-bf15-ebf6-f791" hidden="false">
              <description>In close combat Tyrannic War Veterans can choose to use krak grenades as close combat weapons. Regardless of the number of attacks on a model&apos;s profile and modifiers for charging or having two weapons, each model may only make one attack with a krak grenade, hitting on a 6+ normally, or 3+ if against a Preferred Enemy. Any hits are resolved at Strength 6, ignoring Armour Saves.</description>
            </rule>
          </rules>
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="152b-d5a3-64e0-0fce-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="152b-d5a3-64e0-0fce-max" includeChildSelections="false"/>
