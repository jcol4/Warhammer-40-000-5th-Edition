                  <profiles>
                    <profile name="Runic Armour" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="8fd4-7d1e-5a96-2137">
                      <characteristics>
                        <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Runic Armour has the same effect as Artificer Armour, providing the wearer a 2+ Armour Save.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <modifiers>
                    <modifier type="set" value="2+" field="5.361766523232344e+27" scope="root-entry" affects="self.entries.profiles.Unit"/>
                    <modifier type="set" value="true" field="hidden">
