    <selectionEntry type="model" import="true" name="Rune Priest" hidden="false" id="e7b3-4619-9484-a9a7">
      <categoryLinks>
        <categoryLink name="HQ" hidden="false" id="1241-f46d-d805-58c3" targetId="0d45-9523-cfd8-4efd" primary="true"/>
        <categoryLink name="Space Wolf" hidden="false" id="9a75-76cb-3b46-e780" targetId="407e-febc-7e2c-0621" primary="false"/>
        <categoryLink name="Character" hidden="false" id="84c9-619c-bd23-6365" targetId="c918-96c1-1ff1-3df1" primary="false"/>
      </categoryLinks>
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Psychic Power - Storm Caller" hidden="false" id="50b6-0eb0-ba42-8019" sortIndex="1">
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="432e-6a76-65c4-5892-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="432e-6a76-65c4-5892-max" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="Psychic Power - Storm Caller" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="3585-904b-3c9a-99e2">
              <characteristics>
                <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">In the Shooting phase of the Space Wolves turn, the Rune Priest can use his psychic powers to call up a blizzard of psychic energy that can be used to hide friendly troops from the enemy. He may not shoot on the same turn that he calls up the storm. If he successfully uses the power then he can summon the storm either over himself and the unit he is with or over any friendly unit that has a model within 12&quot; of him. This unit counts as being in cover for rules purposes and so will receive a 5+ cover save and will strike first in close combat until the end of the following enemy turn. Units that are protected in this way may assault and, if they do so and the enemy are also in cover, attacks are resolved in order of initiative.


If a unit with Storm Caller on it charges an opponent with either frag or plasma grenades, they will strike first as these grenades are of no use when receiving a charge.


Storm Caller can be cast on friendly vehicles, which count as being obscured.


Remember that cover only counts in the first round of close combat and subsequent attacks will occur in normal order. Weapons that strike last will still strike last.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
      <entryLinks>
        <entryLink import="true" name="Armoury" hidden="false" id="1176-4d01-aa7c-dae0" type="selectionEntryGroup" targetId="5436-00fc-8e0b-d361" sortIndex="2"/>
