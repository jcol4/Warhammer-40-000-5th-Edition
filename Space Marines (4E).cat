          </conditions>
        </modifier>
      </modifiers>
      <infoLinks>
        <infoLink name="Deep Strike" id="df59-66b5-014b-9b1e" hidden="false" type="rule" targetId="bbf5-b1c2-49b0-f3c2"/>
      </infoLinks>
    </selectionEntry>
