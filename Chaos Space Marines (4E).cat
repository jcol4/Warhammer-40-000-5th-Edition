    <selectionEntry type="upgrade" import="true" name="Daemonic Steed" hidden="false" id="0654-e590-baa2-abb4">
      <profiles>
        <profile name="Daemonic Steed (Mount of Slaanesh)" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="true" id="53c5-b07f-545c-e795">
          <characteristics>
            <characteristic name="Details" typeId="acf3-d214-6e51-29fe">A Mount of Slaanesh confers to the rider +1 Attack and changes the unit type to Cavalry</characteristic>
