                <selectionEntryGroup name="Command Squad Upgrades" id="9fa0-8687-082c-7a1b" hidden="true" flatten="true">
                  <selectionEntries>
                    <selectionEntry type="upgrade" import="true" name="Standard Bearer" hidden="false" id="9b84-bda7-be31-50c7">
                      <selectionEntries>
                        <selectionEntry type="upgrade" import="true" name="Ravenwing Company Standard" hidden="false" id="4847-e797-ff00-a518">
                          <constraints>
                            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="12e9-9fcd-f24e-2a99-min" includeChildSelections="false"/>
                            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="12e9-9fcd-f24e-2a99-max" includeChildSelections="false"/>
                          </constraints>
                          <profiles>
                            <profile name="Ravenwing Company Standard" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="0bf1-10bd-6ff5-4af6">
                              <characteristics>
                                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Any Dark Angels unit within 12&quot; of the standard may re-roll any failed Morale and Pinning tests. In addition, all models win the standard bearer&apos;s unit adds 1 to their Attacks characteristic.</characteristic>
                              </characteristics>
                            </profile>
                          </profiles>
                          <modifiers>
                            <modifier type="increment" value="1" field="4.123232344415441e+21" affects="self.entries.profiles.Unit" scope="root-entry"/>
                          </modifiers>
                        </selectionEntry>
                      </selectionEntries>
                      <constraints>
                        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="80d4-a5ff-80d6-7859" includeChildSelections="true"/>
                      </constraints>
                      <costs>
                        <cost name="Points" typeId="4deb-313d-6685-f48b" value="25"/>
                      </costs>
                    </selectionEntry>
                    <selectionEntry type="upgrade" import="true" name="Apothecary" hidden="false" id="1dab-4fb4-f3fe-d9f4">
                      <selectionEntries>
                        <selectionEntry type="upgrade" import="true" name="Narthecium &amp; Reductor" hidden="false" id="37fc-2ac7-e12e-a394">
                          <constraints>
                            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="d7a4-120f-f3db-3d08-min" includeChildSelections="false"/>
                            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="d7a4-120f-f3db-3d08-max" includeChildSelections="false"/>
                          </constraints>
                          <profiles>
                            <profile name="Narthecium" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="f385-998c-ee39-8797">
                              <characteristics>
                                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">In order to use this equipment, the Apothecary cannot be Falling Back, Locked in close combat, or Pinned.
He may treat any friendly non-vehicle model within 6&quot; of him. Once per turn he may use his narthecium to allow a treatable model to ignore a failed Save (of any sort). It is, however, of no use against an attack that causes Instant Death or a close combat attack that ignores Armour Saves.</characteristic>
                              </characteristics>
                            </profile>
                            <profile name="Reductor" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="b6dc-6867-7148-3752">
                              <characteristics>
                                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">In order to use this equipment, the Apothecary cannot be Falling Back, Locked in close combat, or Pinned.
He may treat any friendly non-vehicle model within 6&quot; of him. In the enemy Shooting phase, the Apothecary can use his reductor to recover the gene-seed of any treatable models that are killed within 6&quot; of him. These casualties are ignored when determining if their units have to take a Morale test for suffering 25% shooting casualties. For examaple, a unit suffers four casualties out of nine but two of them are within 6&quot; of the Apothecary, so no Morale test is taken.</characteristic>
                              </characteristics>
                            </profile>
                          </profiles>
                        </selectionEntry>
                      </selectionEntries>
                      <constraints>
                        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="33f6-d100-c6e6-ffb6" includeChildSelections="true"/>
                      </constraints>
                      <costs>
                        <cost name="Points" typeId="4deb-313d-6685-f48b" value="15"/>
                      </costs>
                    </selectionEntry>
                  </selectionEntries>
