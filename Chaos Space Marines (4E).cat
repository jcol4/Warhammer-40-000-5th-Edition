      <rules>
        <rule name="Inferno Bolts" id="d73f-cc14-7841-1cfa" hidden="false">
          <description>The AP value of the unit&apos;s bolt weapons is 3 instead of 5.</description>
        </rule>
        <rule name="The Sorcerer Commands" id="d935-5ec1-6376-24ab" hidden="false">
          <description>The Aspiring Sorcerer who leads the squad is a psyker. If the Aspiring Sorcerer is killed, the Thousand Sons marines roll a single dice for their Slow and Purposeful movement, unless the squad includes an Independent Character with the Mark of Tzeentch from the beginning of the turn.</description>
        </rule>
