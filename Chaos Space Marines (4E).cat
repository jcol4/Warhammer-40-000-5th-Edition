            <characteristic name="Strength" typeId="537472656e67746823232344415441232323">4</characteristic>
            <characteristic name="AP" typeId="4.1502323234441545e+23">3</characteristic>
            <characteristic name="Type" typeId="8b10-045a-f593-605e">Assault D6</characteristic>
            <characteristic name="Info" typeId="33e9-27bd-77e4-401d">If a 1 is rolled for the number of shots, no shots are fired and the wilder suffers a wound with no Armour Save allowed.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="parent" childId="2b54-9305-b1dd-a202" shared="true" childName="Mark of Tzeentch"/>
