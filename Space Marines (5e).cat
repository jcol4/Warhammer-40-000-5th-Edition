    <selectionEntry type="upgrade" import="true" name="Rosarius" hidden="false" id="chp0-ros-0000-0001" collective="false">
      <costs>
        <cost name="Points" typeId="4deb-313d-6685-f48b" value="0"/>
      </costs>
      <profiles>
        <profile name="Rosarius" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="chp0-ros-prof-0001">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A Rosarius is a gorget or amulet worn by Chaplains. It protects the Chaplain from physical and spiritual harm. A Rosarius confers a 4+ invulnerable save.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Teleport Homer" hidden="false" id="tact-th-0001" collective="false">
      <costs>
        <cost name="Points" typeId="4deb-313d-6685-f48b" value="0"/>
      </costs>
      <profiles>
        <profile name="Teleport Homer" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="tact-th-0002">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Any friendly unit with the Deep Strike special rule may use the bearer&apos;s location as a reference point when Deep Striking, rather than the usual scattering method. The bearer must be on the table when the unit begins to Deep Strike.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Signum" hidden="false" id="devs-sg-signum-0001" collective="false">
      <costs>
        <cost name="Points" typeId="4deb-313d-6685-f48b" value="0"/>
      </costs>
      <profiles>
        <profile name="Signum" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="devs-sg-signum-prof-0001">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A model can use a signum in lieu of making a shooting attack of his own. If he does so, one model in his squad is Ballistic Skill 5 for the remainder of the Shooting phase. Declare that the signum is being used before any rolls to hit are made.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
