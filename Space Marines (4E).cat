      <profiles>
        <profile name="Terminator Honours" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="b2f2-f962-ca28-466b">
          <characteristics>
            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A model with Terminator Honours adds +1 to its Attacks characteristic. In addition its Leadership characteristic is increased to 9 if originally lower.
In NewRecruit these bonuses should be automatically applied to a unit&apos;s profile when Terminator Honours are selected.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <modifiers>
        <modifier type="floor" value="9" field="4c4423232344415441232323" affects="entries.profiles.Unit" position="1" scope="parent">
