      <rules>
        <rule name="Rites of Battle" id="e258-c3cf-c790-655c" hidden="false">
          <description>If a Company Master is on the table then all other Dark Angels units may use his Leadership for Morale, Pinning, or Leadership tests, but not Psychic tests.</description>
        </rule>
        <rule name="Inspiring" id="0ba3-13c0-240c-439c" hidden="false">
          <description>If Dante is included in a Blood Angels army, then any friendly unit of Blood Angels within 12&quot; of him counts its opponents as a preferred enemy.</description>
        </rule>
      </rules>
