      <rules>
        <rule name="Rites of Battle" id="7d2a-582c-9a82-80a7" hidden="false">
          <description>If a Company Master is on the table then all other Dark Angels units may use his Leadership for Morale, Pinning, or Leadership tests, but not Psychic tests.</description>
        </rule>
