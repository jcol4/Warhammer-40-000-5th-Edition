      <rules>
        <rule name="Honour of the Chapter" id="05a8-e676-7054-6d52" hidden="false">
          <description>Chaplains embody the honour of their Chapter. They, and all members of any Space Marine squad they have joined, lead, or attached to are Fearless.</description>
        </rule>
        <rule name="Litanies of Hate" id="e1a6-ca61-c695-63f6" hidden="false">
          <description>On a player turn in which he charges into close combat, a Chaplain, and all members of any Space Marine squad he has joined, leads, or is attached to may re-roll failed rolls to hit.</description>
        </rule>
      </rules>
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Death Mask" hidden="false" id="f4e4-97e4-2c01-dcbc" sortIndex="4">
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="218e-296b-c308-4306-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="218e-296b-c308-4306-max" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="Death Mask" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="18b8-ef10-cdbe-da79">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Any enemy unit within 6&quot; of a model wearing the Death Mask suffers a -1 modifier to its Leadership.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Crozius Arcanum" hidden="false" id="4fb5-829d-1cc8-ea55" sortIndex="2">
