  <sharedRules>
    <rule name="Wolf Guard Bodyguard" id="75df-22ef-dab8-7f56" hidden="false">
      <description>May be accompanied by a Wolf Guard bodyguard. See Wolf Guard entry for details.</description>
    </rule>
  </sharedRules>
  <rules>
    <rule name="Blood Feud" id="9760-9bf7-0090-32cd" hidden="false">
      <description>When fighting against Dark Angels or Thousand Sons a Space Wolf will hit on a roll of 3+ in close combat regardless of the models&apos; respective Weapon Skills. Likewise Dark Angels and Thousand Sons opponents will also hit on 3+.</description>
    </rule>
    <rule name="No Matter the Odds" id="862a-10b3-a07d-c56e" hidden="false">
      <description>Space Wolves may ignore the negative Morale check modifiers for being outnumbered in close combat.</description>
    </rule>
    <rule name="Will Not Teleport" id="cc6e-4800-5efc-4f69" hidden="false">
      <description>Space Wolves in Terminator armour may not deep strike unless the entire army</description>
    </rule>
  </rules>
