                    </selectionEntry>
                    <selectionEntry type="upgrade" import="true" name="Dark Angels Chapter Banner" hidden="true" id="92fd-29ab-2604-dcf5">
                      <costs>
                        <cost name="Points" typeId="4deb-313d-6685-f48b" value="15"/>
                      </costs>
                      <constraints>
                        <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="7cc2-9eb1-fd45-f028" includeChildSelections="true" automatic="true"/>
                      </constraints>
                      <profiles>
                        <profile name="Dark Angels Chapter Banner" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="6e62-2d40-9995-5829">
                          <characteristics>
                            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">Any Dark Angels unit within 12&quot; of the standard may re-roll any failed Morale and Pinning tests. In addition, all models win the standard bearer&apos;s unit adds 1 to their Attacks characteristic.</characteristic>
                          </characteristics>
                        </profile>
