            <characteristic name="Sv" typeId="5.361766523232344e+27">3+</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="3e29-3679-5fab-84e0" includeChildSelections="true"/>
      </constraints>
      <modifiers>
        <modifier type="set" value="0" field="3e29-3679-5fab-84e0">
          <conditions>
            <condition type="lessThan" value="1500" field="4deb-313d-6685-f48b" scope="force" childId="any" shared="true" includeChildSelections="true"/>
          </conditions>
        </modifier>
      </modifiers>
      <infoLinks>
        <infoLink name="Litanies of Hate" id="0c72-cc4e-a099-61cb" hidden="false" type="rule" targetId="99d7-eaaa-fb97-4d39"/>
        <infoLink name="Unmatched Zeal" id="5336-9346-caf7-4e6a" hidden="false" type="rule" targetId="f36d-9875-3d5f-fddb"/>
      </infoLinks>
      <rules>
        <rule name="Only in Death does Duty End" id="0e50-10ec-46aa-6fa4" hidden="false">
          <description>Once Grimaldus has lost all of his Wounds (even if caused by a weapon that causes Instant Death), do not remove him from play. Instead, take a Leadership test and if this is passed, Grimaldus fights on with 1 Wound remaining. If he loses this Wound remove him from the table. Grimaldus must take a Leadership test at the beginning of each game turn for the rest of the battle. If this is passed he fights on, but if it is failed he is removed from play.</description>
        </rule>
      </rules>
    </selectionEntry>
