            <repeat value="1" repeats="1" field="selections" scope="parent" childId="4751-3267-a4ca-7c31" shared="true" roundUp="false" childName="Vindicator"/>
            <repeat value="1" repeats="1" field="selections" scope="parent" childId="8f7c-5d7e-e32d-05f9" shared="true" roundUp="false" childName="Dreadnought"/>
