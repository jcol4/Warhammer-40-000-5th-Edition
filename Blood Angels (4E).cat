                <modifier type="append" value="Twin-linked" field="8b10-045a-f593-605e" join=", "/>
              </modifiers>
            </infoLink>
          </infoLinks>
          <profiles>
            <profile name="Servo-Harness" typeId="57617267656172204974656d23232344415441232323" typeName="Wargear" hidden="false" id="ac58-1aca-8c59-f177">
              <characteristics>
                <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A servo-harness incorporates the following features: artificer armour, a second servo-arm (giving two servo-arm attacks), a plasma cutter (which counts as a twin-linked plasma pistol), and a flamer. In the Shooting phase the Techmarine may fire both harness-mounted weapons or one harness-mounted weapon and one of his personal weapons. A Techmarine with a servo-harness may reroll the dice when attempting to repair a damaged vehicle (See Blessing of the Omnissiah special rule).</characteristic>
              </characteristics>
            </profile>
            <profile name="Servo-arm" typeId="b729-49a4-4123-cf00" typeName="Melee Weapon" hidden="false" id="2e20-8d4a-bf2f-9235">
              <characteristics>
                <characteristic name="Details" typeId="acf3-d214-6e51-29fe">The servo-arm grants the model one additional close combat attack, made at Initiative 1 and Strength 8, ignoring Armour Saves.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
