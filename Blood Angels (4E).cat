    <selectionEntry type="upgrade" import="true" name="Mephiston, Lord of Death" hidden="false" id="089a-e9eb-f8aa-832b">
      <profiles>
        <profile name="Chief Librarian Mephiston" typeId="556e697423232344415441232323" typeName="Unit" hidden="false" id="c293-3a33-3330-65d8">
          <characteristics>
            <characteristic name="Unit Type" typeId="556e6974205479706523232344415441232323">Infantry, Character</characteristic>
            <characteristic name="WS" typeId="5.753232323444154e+23">6</characteristic>
            <characteristic name="BS" typeId="4.2532323234441546e+23">5</characteristic>
            <characteristic name="S" typeId="5.323232344415441e+21">5</characteristic>
            <characteristic name="T" typeId="5.423232344415441e+21">5</characteristic>
            <characteristic name="W" typeId="5.723232344415441e+21">3</characteristic>
