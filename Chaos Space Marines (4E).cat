    <selectionEntry type="unit" import="true" name="Chaos Spawn" hidden="false" id="708f-b16e-59bd-d079">
      <categoryLinks>
        <categoryLink name="Additional Units" hidden="false" id="bfc7-9cf8-6b3a-0eba" targetId="0589-7c29-bfa2-d566" primary="true"/>
      </categoryLinks>
      <rules>
        <rule name="Chaos Spawn" id="97ae-a5e0-f3cc-ad36" hidden="false">
          <description>Your army may include any number of units of Chaos Spawn. Units of Chaos Spawn do not use up any Force Organisation Chart selection, but are otherwise treated as a Fast Attack unit. All of the Spawn in the Force must be divided into as few squads as possible</description>
        </rule>
        <rule name="Mindless" id="b470-a36e-0833-0943" hidden="false">
          <description>Units of Chaos Spawn always move as far as they can towards the closest enemy. They must always try to assault the closest enemy. In close combat each Spawn has D6 Attacks - roll every time they are about to attack. Units of Chaos Spawn never count as scoring units.</description>
        </rule>
      </rules>
      <selectionEntries>
        <selectionEntry type="model" import="true" name="Chaos Spawn" hidden="false" id="04fe-7868-58c1-eea5">
          <costs>
            <cost name="Points" typeId="4deb-313d-6685-f48b" value="40"/>
          </costs>
          <comment>Model</comment>
          <profiles>
