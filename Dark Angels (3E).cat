      <rules>
        <rule name="Know Thine Enemy" id="da01-bece-6953-9f19" hidden="false">
          <description>If an army includes Ezekiel, the Dark Angels player may, if he chooses, demand that his opponent set up D6 units before any of the Dark Angels deploy. The Dark Angels player may pick which D6 units are affected, even if units must normally be deployed in a special order during the mission set-up.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink name="Stubborn" id="ff23-d90a-7701-1ad0" hidden="false" type="rule" targetId="e74d-09c0-8669-dbfa"/>
      </infoLinks>
      <profiles>
        <profile name="Ezekiel, Grand Master of the Librarians" typeId="556e697423232344415441232323" typeName="Unit" hidden="false" id="10da-d405-280e-a63d">
          <characteristics>
            <characteristic name="Unit Type" typeId="556e6974205479706523232344415441232323">Infantry, Character, Psyker</characteristic>
