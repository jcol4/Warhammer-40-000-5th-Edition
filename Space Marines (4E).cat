              </modifiers>
              <entryLinks>
                <entryLink import="true" name="The Lion Helm" hidden="false" id="dafd-60bb-b4bc-b887" type="selectionEntry" targetId="16a3-b6bd-23d3-02a9"/>
              </entryLinks>
            </selectionEntryGroup>
          </selectionEntryGroups>
