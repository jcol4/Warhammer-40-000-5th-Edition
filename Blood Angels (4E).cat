                          <characteristics>
                            <characteristic name="Description" typeId="4465736372697074696f6e23232344415441232323">A Company Standard allows any Space Marine unit with at last one model within 12&quot; of the standard to re-roll any failed Morale or Pinning test.</characteristic>
                          </characteristics>
                          <alias>Company Banner</alias>
                        </profile>
                      </profiles>
